---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../lib/affiliate-data';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VergelijkSlim.nl',
  url: Astro.site?.href,
  description: 'Onafhankelijke vergelijkingen en reviews voor de Nederlandse markt',
  inLanguage: 'nl',
};

const niches = [
  {
    title: 'Zonnepanelen & Energie',
    description: 'Vergelijk zonnepanelen, energieleveranciers en bespaar op uw energierekening.',
    href: '/zonnepanelen/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
    color: '#f59e0b',
    bgColor: '#fef3c7',
  },
  {
    title: 'Hosting & SaaS',
    description: 'De beste webhosting en software tools voor Nederlandse ondernemers en websites.',
    href: '/hosting/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
    color: '#1a56db',
    bgColor: '#e8f0fe',
  },
  {
    title: 'Woningverbetering',
    description: 'Kosten, tips en offertes voor verbouwingen, renovaties en onderhoud.',
    href: '/woningverbetering/',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    color: '#047857',
    bgColor: '#ecfdf5',
  },
];

const allZonnepanelen = (await getCollection('zonnepanelen')).filter(a => !a.data.draft && a.data.featured);
const allHosting = (await getCollection('hosting')).filter(a => !a.data.draft && a.data.featured);
const allWoning = (await getCollection('woningverbetering')).filter(a => !a.data.draft && a.data.featured);

const featured = [
  ...allZonnepanelen.map(a => ({ ...a, niche: 'zonnepanelen' })),
  ...allHosting.map(a => ({ ...a, niche: 'hosting' })),
  ...allWoning.map(a => ({ ...a, niche: 'woningverbetering' })),
].sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()).slice(0, 6);

const typeLabels: Record<string, string> = {
  vergelijking: 'Vergelijking',
  review: 'Review',
  gids: 'Gids',
  regionaal: 'Regionaal',
};

function estimateReadTime(body: string): number {
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 250));
}
---

<BaseLayout
  title="VergelijkSlim.nl — Slim vergelijken, beter kiezen"
  description="Onafhankelijke vergelijkingen en reviews van zonnepanelen, webhosting en woningverbetering voor de Nederlandse markt."
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-content">
      <span class="hero-badge">Onafhankelijk & Eerlijk</span>
      <h1>Slim vergelijken,<br />beter kiezen</h1>
      <p class="hero-sub">
        Vergelijk producten en diensten op basis van prijs, kwaliteit en betrouwbaarheid.
        Onze redactie onderzoekt, test en beoordeelt — zodat u de juiste keuze maakt.
      </p>
      <div class="hero-cta">
        <a href="#categorieen" class="btn btn-cta">Bekijk categorieën</a>
      </div>
    </div>
  </section>

  <section class="trust-bar">
    <div class="container">
      <div class="trust-items">
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>100% onafhankelijk</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Betrouwbare reviews</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span>Voor Nederlandse consumenten</span>
        </div>
      </div>
    </div>
  </section>

  <section class="niches" id="categorieen">
    <div class="container">
      <div class="section-header">
        <h2>Onze categorieën</h2>
        <p>Kies een categorie en ontdek onze vergelijkingen en reviews.</p>
      </div>
      <div class="niche-grid">
        {niches.map((niche) => (
          <a href={niche.href} class="niche-card">
            <div class="niche-icon" style={`background: ${niche.bgColor}; color: ${niche.color};`}>
              <Fragment set:html={niche.icon} />
            </div>
            <h3>{niche.title}</h3>
            <p>{niche.description}</p>
            <span class="niche-link">Bekijk artikelen &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="featured">
      <div class="container">
        <div class="section-header">
          <h2>Uitgelichte artikelen</h2>
          <p>Onze meest populaire vergelijkingen en reviews.</p>
        </div>
        <div class="featured-grid">
          {featured.map((article) => (
            <a href={`/${article.niche}/${article.id}/`} class="featured-card">
              <div class="featured-card-top">
                <span class="badge badge-primary">{typeLabels[article.data.type] || article.data.type}</span>
              </div>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <div class="featured-card-meta">
                <span>{article.data.author}</span>
                <span>·</span>
                <span>{article.data.publishDate.toLocaleDateString('nl-NL', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #1a56db 100%);
    color: #fff;
    padding: 4rem 0 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
  }
  .hero-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(4px);
  }
  .hero h1 {
    color: #fff;
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .hero-sub {
    font-size: 1.125rem;
    opacity: 0.85;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 2rem;
  }
  .hero-cta .btn {
    font-size: 1rem;
    padding: 0.875rem 2rem;
  }
  @media (min-width: 768px) {
    .hero { padding: 6rem 0 7rem; }
    .hero h1 { font-size: 3.5rem; }
    .hero-sub { font-size: 1.25rem; }
  }

  .trust-bar {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }
  .trust-items {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-light);
  }
  .trust-item svg {
    color: var(--color-secondary);
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .trust-items { gap: 3rem; }
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-header p {
    color: var(--color-text-light);
    font-size: 1.0625rem;
    margin-top: 0.5rem;
  }

  .niches {
    padding: 4rem 0;
  }
  .niche-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .niche-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .niche-card {
    display: block;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    color: var(--color-text);
    background: var(--color-bg);
    transition: all var(--transition-base);
  }
  .niche-card:hover {
    text-decoration: none;
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    border-color: transparent;
  }
  .niche-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    margin-bottom: 1.25rem;
  }
  .niche-card h3 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .niche-card p {
    color: var(--color-text-light);
    font-size: 0.9375rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  .niche-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .featured {
    padding: 4rem 0;
    background: var(--color-bg-alt);
  }
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .featured-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .featured-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .featured-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    transition: all var(--transition-base);
  }
  .featured-card:hover {
    text-decoration: none;
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .featured-card-top {
    margin-bottom: 0.75rem;
  }
  .featured-card h3 {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  .featured-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    line-height: 1.6;
    flex: 1;
  }
  .featured-card-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border-light);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>
