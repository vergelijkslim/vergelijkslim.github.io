---
import BaseLayout from '../layouts/BaseLayout.astro';
import AffiliateButton from '../components/AffiliateButton.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import '../lib/affiliate-data';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Gratis Offertes Aanvragen - SlimZonnig.nl',
  description: 'Vraag gratis en vrijblijvend offertes aan voor zonnepanelen. Vergelijk aanbieders en bespaar tot 40% op je installatie.',
};

const steps = [
  {
    number: '1',
    title: 'Vul je gegevens in',
    description: 'Vertel ons over je dak, verbruik en wensen. Duurt maar 2 minuten.',
  },
  {
    number: '2',
    title: 'Ontvang offertes',
    description: 'Binnen 48 uur ontvang je tot 4 offertes van gecertificeerde installateurs bij jou in de buurt.',
  },
  {
    number: '3',
    title: 'Vergelijk en bespaar',
    description: 'Vergelijk prijs, kwaliteit en voorwaarden. Kies de aanbieder die het beste bij je past.',
  },
];

const benefits = [
  { title: '100% gratis', description: 'Geen kosten, geen verplichtingen' },
  { title: 'Gecertificeerde installateurs', description: 'Alleen SCIOS- en Techniek NL-gecertificeerd' },
  { title: 'Tot 4 offertes', description: 'Vergelijk en bespaar tot 40%' },
  { title: 'Binnen 48 uur', description: 'Snel reactie van lokale vakmensen' },
];
---

<BaseLayout
  title="Gratis Offertes Aanvragen voor Zonnepanelen"
  description="Vraag gratis en vrijblijvend offertes aan voor zonnepanelen. Vergelijk aanbieders en bespaar tot 40% op je installatie."
  structuredData={structuredData}
>
  <section class="offerte-hero">
    <div class="container hero-content">
      <span class="hero-badge">Gratis & Vrijblijvend</span>
      <h1>Vergelijk offertes voor<br />zonnepanelen</h1>
      <p class="hero-sub">
        Ontvang tot 4 offertes van gecertificeerde installateurs bij jou in de buurt.
        Vergelijk en bespaar gemiddeld 30% op je zonnepanelen installatie.
      </p>
      <div class="hero-cta">
        <AffiliateButton linkId="zonnepanelen-offerte" label="Vraag gratis offertes aan" variant="cta" />
      </div>
      <p class="hero-note">Meer dan 10.000 huiseigenaren gingen je voor</p>
    </div>
  </section>

  <section class="steps-section">
    <div class="container">
      <h2 class="section-title">Zo werkt het</h2>
      <div class="steps-grid">
        {steps.map((step) => (
          <div class="step-card">
            <div class="step-number">{step.number}</div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="benefits-section">
    <div class="container">
      <h2 class="section-title">Waarom via SlimZonnig?</h2>
      <div class="benefits-grid">
        {benefits.map((benefit) => (
          <div class="benefit-card">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <div>
              <h4>{benefit.title}</h4>
              <p>{benefit.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-bottom">
    <div class="container">
      <div class="cta-card">
        <h2>Klaar om te besparen op je energierekening?</h2>
        <p>Vraag vandaag nog gratis offertes aan en ontdek hoeveel jij kunt besparen met zonnepanelen.</p>
        <div class="cta-buttons">
          <AffiliateButton linkId="zonnepanelen-offerte" label="Vraag gratis offertes aan" variant="cta" />
          <AffiliateButton linkId="installateur-vergelijk" label="Vergelijk installateurs" variant="primary" />
        </div>
        <p class="cta-disclaimer">
          <small>* Wij werken samen met geselecteerde partners. Wanneer je via onze links een offerte aanvraagt, ontvangen wij mogelijk een vergoeding. Dit heeft geen invloed op de prijs die je betaalt.</small>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .offerte-hero {
    background: linear-gradient(135deg, #064e3b 0%, #047857 40%, #059669 70%, #10b981 100%);
    color: #fff;
    padding: 4rem 0 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .offerte-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(167,243,208,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
  }
  .hero-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(4px);
  }
  .offerte-hero h1 {
    color: #fff;
    font-size: 2.25rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .hero-sub {
    font-size: 1.125rem;
    opacity: 0.9;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 2rem;
  }
  .hero-cta {
    margin-bottom: 1rem;
  }
  .hero-cta :global(.btn) {
    background: #fff;
    color: #047857;
    font-size: 1.0625rem;
    padding: 1rem 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }
  .hero-cta :global(.btn:hover) {
    background: #f0fdf4;
    color: #065f46;
    box-shadow: var(--shadow-xl);
  }
  .hero-note {
    font-size: 0.8125rem;
    opacity: 0.7;
  }
  @media (min-width: 768px) {
    .offerte-hero { padding: 6rem 0 7rem; }
    .offerte-hero h1 { font-size: 3rem; }
    .hero-sub { font-size: 1.25rem; }
  }

  .section-title {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .steps-section {
    padding: 4rem 0;
    background: var(--color-bg-alt);
  }
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .steps-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .step-card {
    text-align: center;
    padding: 2rem 1.5rem;
  }
  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-secondary);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
    font-family: var(--font-sans);
    margin-bottom: 1rem;
  }
  .step-card h3 {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .step-card p {
    color: var(--color-text-light);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .benefits-section {
    padding: 4rem 0;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 700px;
    margin: 0 auto;
  }
  @media (min-width: 640px) {
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .benefit-card {
    display: flex;
    gap: 0.875rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-fast);
  }
  .benefit-card:hover {
    border-color: var(--color-secondary);
  }
  .benefit-card svg {
    flex-shrink: 0;
    color: var(--color-secondary);
    margin-top: 2px;
  }
  .benefit-card h4 {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.125rem;
  }
  .benefit-card p {
    color: var(--color-text-light);
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .cta-bottom {
    padding: 0 0 4rem;
  }
  .cta-card {
    background: linear-gradient(135deg, #ecfdf5 0%, #f0fdf4 100%);
    border: 1px solid #bbf7d0;
    border-radius: var(--radius-xl);
    padding: 3rem 2rem;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .cta-card h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .cta-card > p {
    color: var(--color-text-light);
    font-size: 1rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .cta-disclaimer {
    margin: 0;
  }
  .cta-disclaimer small {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    line-height: 1.5;
  }
</style>
