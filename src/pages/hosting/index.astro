---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import { getCollection } from 'astro:content';
import '../../lib/affiliate-data';

const articles = (await getCollection('hosting'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Hosting & SaaS', href: '/hosting/' },
];
---

<BaseLayout
  title="Beste Webhosting & SaaS Vergelijken – Reviews & Prijzen"
  description="Vergelijk de beste webhosting providers en SaaS tools voor de Nederlandse markt. Onafhankelijke reviews en eerlijke vergelijkingen."
>
  <BreadcrumbSchema items={breadcrumbs} />

  <section class="category-hero">
    <div class="container">
      <h1>Hosting & SaaS vergelijken</h1>
      <p>Onafhankelijke reviews van webhosting, website builders en software tools.</p>
    </div>
  </section>

  <section class="articles">
    <div class="container">
      <div class="article-grid">
        {articles.map((article) => (
          <a href={`/hosting/${article.id}/`} class="article-card">
            <h2>{article.data.title}</h2>
            <p>{article.data.description}</p>
            <span class="article-meta">
              {article.data.publishDate.toLocaleDateString('nl-NL')}
              {' · '}
              {article.data.type}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-hero {
    background: var(--color-bg-alt);
    padding: 3rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .category-hero h1 { margin-bottom: 0.5rem; }
  .category-hero p { color: var(--color-text-light); font-size: 1.125rem; }
  .articles { padding: 2rem 0; }
  .article-grid { display: grid; gap: 1.5rem; }
  .article-card {
    display: block; padding: 1.5rem;
    border: 1px solid var(--color-border); border-radius: 0.5rem;
    color: var(--color-text); transition: box-shadow 0.2s;
  }
  .article-card:hover { text-decoration: none; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .article-card h2 { font-size: 1.25rem; margin-bottom: 0.5rem; }
  .article-card p { color: var(--color-text-light); font-size: 0.9375rem; margin-bottom: 0.5rem; }
  .article-meta { font-size: 0.8125rem; color: var(--color-text-light); }
</style>
