---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';
import { getCollection, render } from 'astro:content';
import '../../lib/affiliate-data';

export async function getStaticPaths() {
  const articles = await getCollection('hosting');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { title, description, faq, affiliateLinks, publishDate, author } = article.data;

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Hosting & SaaS', href: '/hosting/' },
  { name: title, href: `/hosting/${article.id}/` },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  author: { '@type': 'Organization', name: author },
  publisher: { '@type': 'Organization', name: 'VergelijkSlim.nl' },
};
---

<BaseLayout title={title} description={description} structuredData={articleSchema}>
  <BreadcrumbSchema items={breadcrumbs} />
  {faq.length > 0 && <FAQSchema items={faq} />}

  <article class="article-content">
    <div class="container content-wrapper">
      <header>
        <h1>{title}</h1>
        <p class="article-meta">
          Door {author} · {publishDate.toLocaleDateString('nl-NL')}
        </p>
      </header>

      <div class="prose">
        <Content />
      </div>

      {affiliateLinks.length > 0 && (
        <div class="cta-box">
          {affiliateLinks.map((linkId) => (
            <AffiliateButton linkId={linkId} />
          ))}
        </div>
      )}

      {faq.length > 0 && (
        <section class="faq-section">
          <h2>Veelgestelde vragen</h2>
          {faq.map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </section>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .article-content { padding: 2rem 0; }
  .content-wrapper { max-width: var(--content-width); }
  .article-content h1 { margin-bottom: 0.5rem; }
  .article-meta { color: var(--color-text-light); font-size: 0.875rem; margin-bottom: 2rem; }
  .prose :global(h2) { margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose :global(h3) { margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .prose :global(p) { margin-bottom: 1rem; }
  .prose :global(ul), .prose :global(ol) { margin-bottom: 1rem; padding-left: 1.5rem; }
  .prose :global(li) { margin-bottom: 0.25rem; }
  .cta-box {
    background: #f0fdf4; border: 2px solid #86efac;
    border-radius: 0.75rem; padding: 2rem; text-align: center; margin: 2rem 0;
  }
  .faq-section { margin-top: 2rem; }
  .faq-section h2 { margin-bottom: 1rem; }
  .faq-item {
    border: 1px solid var(--color-border); border-radius: 0.5rem;
    margin-bottom: 0.75rem; overflow: hidden;
  }
  .faq-item summary { padding: 1rem; cursor: pointer; font-weight: 600; background: var(--color-bg-alt); }
  .faq-item p { padding: 1rem; }
</style>
