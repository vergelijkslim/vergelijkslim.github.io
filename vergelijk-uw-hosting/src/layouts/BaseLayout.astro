---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  structuredData?: object | object[];
}

const {
  title, description,
  canonical = Astro.url.href,
  ogImage = '/images/og-default.jpg',
  noindex = false,
  structuredData,
} = Astro.props;

const siteName = 'Vergelijk-uw-Hosting.nl';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
---
<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="nl_NL" />
  <title>{fullTitle}</title>
  {structuredData && (
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  )}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Lora:wght@600;700&display=swap" rel="stylesheet" />

  <!-- GA4: activated when PUBLIC_GA4_ID env var is set (e.g. G-XXXXXXXXXX) -->
  {import.meta.env.PUBLIC_GA4_ID && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_ID}`}></script>
      <script define:vars={{ ga4Id: import.meta.env.PUBLIC_GA4_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', ga4Id, { anonymize_ip: true });
        document.addEventListener('DOMContentLoaded', function () {
          document.querySelectorAll('a[data-affiliate-id], a[rel~="sponsored"]').forEach(function (el) {
            el.addEventListener('click', function () {
              gtag('event', 'affiliate_click', { affiliate_id: el.getAttribute('data-affiliate-id') || 'unknown', affiliate_network: el.getAttribute('data-affiliate-network') || 'unknown', page_path: window.location.pathname, link_url: el.href });
            });
          });
          document.querySelectorAll('a[target="_blank"]').forEach(function (el) {
            if (!el.hasAttribute('data-affiliate-id')) {
              el.addEventListener('click', function () { gtag('event', 'outbound_click', { link_url: el.href, page_path: window.location.pathname }); });
            }
          });
        });
      </script>
    </>
  )}
</head>
<body>
  <Header />
  <slot />
  <Footer />
</body>
</html>
