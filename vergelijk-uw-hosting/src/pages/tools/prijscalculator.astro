---
import BaseLayout from '../../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Webhosting prijscalculator – bereken jouw kosten',
  description: 'Bereken jouw maandelijkse webhosting kosten op basis van verwacht verkeer, opslag, e-mail en gewenste functies.',
  url: 'https://vergelijk-uw-hosting.nl/tools/prijscalculator/',
};
---
<BaseLayout
  title="Webhosting Prijscalculator – Bereken Jouw Hostingkosten"
  description="Bereken hoeveel webhosting jou kost op basis van jouw bezoekersaantal, opslagbehoefte en gewenste functies. Vergelijk direct met passende providers."
  structuredData={structuredData}
>
  <main class="tool-page">
    <div class="container">
      <div class="tool-header">
        <h1>Webhosting prijscalculator</h1>
        <p class="tool-intro">Schat jouw maandelijkse hostingkosten op basis van jouw website en wensen.</p>
      </div>

      <div class="calc-layout">
        <!-- Inputs -->
        <div class="calc-inputs">
          <h2>Jouw situatie</h2>

          <div class="field-group">
            <label for="bezoekers">Verwacht maandelijks bezoekersaantal</label>
            <select id="bezoekers">
              <option value="klein">Minder dan 1.000</option>
              <option value="small" selected>1.000 – 10.000</option>
              <option value="medium">10.000 – 50.000</option>
              <option value="large">50.000 – 200.000</option>
              <option value="enterprise">Meer dan 200.000</option>
            </select>
          </div>

          <div class="field-group">
            <label for="opslag">Benodigde opslagruimte</label>
            <select id="opslag">
              <option value="5">Minder dan 5 GB (blog, portfolio)</option>
              <option value="20" selected>5 – 20 GB (gemiddelde site)</option>
              <option value="50">20 – 50 GB (veel afbeeldingen/video)</option>
              <option value="100">50+ GB (webshop, grote site)</option>
            </select>
          </div>

          <div class="field-group">
            <label for="email">Aantal e-mailaccounts</label>
            <select id="email">
              <option value="0">Geen (externe mail)</option>
              <option value="1" selected>1 – 3 e-mails</option>
              <option value="5">4 – 10 e-mails</option>
              <option value="20">Meer dan 10 e-mails</option>
            </select>
          </div>

          <div class="field-group">
            <label>Gewenste functies</label>
            <div class="checkbox-group">
              <label class="check-option"><input type="checkbox" id="featSsl" checked /> Gratis SSL-certificaat</label>
              <label class="check-option"><input type="checkbox" id="featDomein" /> Gratis domeinnaam (1 jaar)</label>
              <label class="check-option"><input type="checkbox" id="featBackup" checked /> Dagelijkse backups</label>
              <label class="check-option"><input type="checkbox" id="featStageing" /> Staging omgeving</label>
              <label class="check-option"><input type="checkbox" id="feat247" checked /> 24/7 support</label>
              <label class="check-option"><input type="checkbox" id="featCdn" /> CDN (snellere laadtijd)</label>
            </div>
          </div>

          <div class="field-group">
            <label for="cms">CMS / Platform</label>
            <select id="cms">
              <option value="wordpress">WordPress</option>
              <option value="custom">Custom / geen CMS</option>
              <option value="woocommerce">WooCommerce (webshop)</option>
              <option value="joomla">Joomla / Drupal</option>
            </select>
          </div>
        </div>

        <!-- Resultaat -->
        <div class="calc-result">
          <h2>Aanbevolen hosting</h2>
          <div id="priceResult"></div>
          <div id="providerRecs"></div>
          <div class="result-cta-block">
            <a href="/tools/vergelijk/" class="btn btn-primary btn-full">Alle providers vergelijken →</a>
          </div>
        </div>
      </div>

      <!-- Tools nav -->
      <div class="tools-nav">
        <h2>Meer tools</h2>
        <div class="tools-grid">
          <a href="/tools/vergelijk/" class="tool-card">
            <span class="tool-icon">📊</span>
            <strong>Hosting vergelijken</strong>
            <span>Filterable vergelijkingstool</span>
          </a>
          <a href="/tools/welke-hosting/" class="tool-card">
            <span class="tool-icon">🧙</span>
            <strong>Welke hosting heb ik nodig?</strong>
            <span>Persoonlijk advies via 5 vragen</span>
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  function calculate() {
    const bezoekers = (document.getElementById('bezoekers') as HTMLSelectElement).value;
    const opslag = parseInt((document.getElementById('opslag') as HTMLSelectElement).value);
    const email = parseInt((document.getElementById('email') as HTMLSelectElement).value);
    const cms = (document.getElementById('cms') as HTMLSelectElement).value;
    const ssl = (document.getElementById('featSsl') as HTMLInputElement).checked;
    const domein = (document.getElementById('featDomein') as HTMLInputElement).checked;
    const backup = (document.getElementById('featBackup') as HTMLInputElement).checked;
    const staging = (document.getElementById('featStageing') as HTMLInputElement).checked;
    const support247 = (document.getElementById('feat247') as HTMLInputElement).checked;
    const cdn = (document.getElementById('featCdn') as HTMLInputElement).checked;

    // Base price by traffic
    let basePrijs = 2.99;
    let hostingType = 'Shared hosting';
    if (bezoekers === 'klein') { basePrijs = 1.99; }
    else if (bezoekers === 'medium') { basePrijs = 6.99; hostingType = 'Business shared / VPS entry'; }
    else if (bezoekers === 'large') { basePrijs = 15.00; hostingType = 'VPS of managed cloud'; }
    else if (bezoekers === 'enterprise') { basePrijs = 35.00; hostingType = 'Managed cloud / dedicated'; }

    // WordPress premium
    if (cms === 'wordpress' && (bezoekers === 'medium' || bezoekers === 'large')) {
      basePrijs = Math.max(basePrijs, 10.00);
      hostingType = 'Managed WordPress hosting';
    }
    if (cms === 'woocommerce') {
      basePrijs = Math.max(basePrijs, 12.00);
      hostingType = 'WordPress + WooCommerce hosting';
    }

    // Extras
    let extraPrijs = 0;
    const extras: string[] = [];

    if (!ssl) { extras.push('SSL via Let\'s Encrypt (gratis bij meeste providers)'); }
    if (domein) { extraPrijs += 0; extras.push('Gratis domein (1e jaar bij veel shared plannen)'); }
    if (backup && bezoekers !== 'klein') { extraPrijs += 1.50; extras.push('+€1,50/mnd voor dagelijkse backups'); }
    if (staging) { extraPrijs += 3.00; extras.push('+€3/mnd staging omgeving'); }
    if (support247 && basePrijs < 5) { extraPrijs += 2.00; extras.push('+€2/mnd voor 24/7 support (basis plans)'); }
    if (cdn) { extraPrijs += 2.50; extras.push('+€2,50/mnd CDN (of gratis via Cloudflare)'); }
    if (email > 5) { extraPrijs += 3.00; extras.push('+€3/mnd extra e-mailaccounts'); }

    const totaalMin = Math.round((basePrijs + extraPrijs) * 100) / 100;
    const totaalMax = Math.round((basePrijs * 1.5 + extraPrijs) * 100) / 100;

    // Providers based on profile
    interface ProviderRec { naam: string; prijs: string; url: string; reden: string; }
    const recs: ProviderRec[] = [];
    if (bezoekers === 'klein' || bezoekers === 'small') {
      if (cms === 'wordpress') recs.push({ naam: 'SiteGround', prijs: 'v.a. €3,99/mnd', url: 'https://www.siteground.com/', reden: 'Beste WordPress performance voor beginners' });
      recs.push({ naam: 'TransIP', prijs: 'v.a. €2,99/mnd', url: 'https://www.transip.nl/webhosting/', reden: 'Betrouwbaar, NL support, gunstige prijs' });
      recs.push({ naam: 'IONOS', prijs: 'v.a. €1,00/mnd', url: 'https://www.ionos.nl/', reden: 'Goedkoopste startoptie met gratis domein' });
    } else if (bezoekers === 'medium') {
      recs.push({ naam: 'Antagonist', prijs: 'v.a. €3,50/mnd', url: 'https://www.antagonist.nl/', reden: 'Uitstekende performance en 24/7 NL support' });
      if (cms === 'wordpress') recs.push({ naam: 'Kinsta', prijs: 'v.a. €35/mnd', url: 'https://kinsta.com/', reden: 'Premium managed WordPress voor groeiende sites' });
      else recs.push({ naam: 'Hetzner VPS', prijs: 'v.a. €4,15/mnd', url: 'https://www.hetzner.com/', reden: 'Kostenefficiënte VPS met uitstekende hardware' });
    } else {
      recs.push({ naam: 'Cloudways', prijs: 'v.a. €14/mnd', url: 'https://www.cloudways.com/', reden: 'Managed cloud met auto-scaling en CDN' });
      recs.push({ naam: 'Kinsta', prijs: 'v.a. €35/mnd', url: 'https://kinsta.com/', reden: 'Enterprise WordPress hosting' });
    }

    document.getElementById('priceResult')!.innerHTML = `
      <div class="price-box">
        <div class="price-type">${hostingType}</div>
        <div class="price-range">€${totaalMin.toFixed(2)} – €${totaalMax.toFixed(2)} <span class="price-unit">/maand</span></div>
        <div class="price-note">Indicatief bij jaarabonnement · excl. domein</div>
      </div>
      ${extras.length > 0 ? `
        <div class="extras-list">
          <h3>Inbegrepen / extra kosten</h3>
          <ul>${extras.map(e => `<li>${e}</li>`).join('')}</ul>
        </div>
      ` : ''}
    `;

    document.getElementById('providerRecs')!.innerHTML = `
      <div class="provider-recs">
        <h3>Aanbevolen voor jou</h3>
        ${recs.map(r => `
          <div class="provider-rec">
            <div>
              <strong>${r.naam}</strong>
              <div class="rec-prijs">${r.prijs}</div>
              <div class="rec-reden">${r.reden}</div>
            </div>
            <a href="${r.url}" rel="nofollow sponsored" target="_blank" class="btn btn-primary btn-sm">Bekijk →</a>
          </div>
        `).join('')}
      </div>
    `;
  }

  const ids = ['bezoekers','opslag','email','cms','featSsl','featDomein','featBackup','featStageing','feat247','featCdn'];
  ids.forEach(id => {
    const el = document.getElementById(id)!;
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>

<style>
  .tool-page { padding: 2rem 0 4rem; }
  .tool-header { margin-bottom: 2rem; }
  .tool-header h1 { margin-bottom: 0.5rem; }
  .tool-intro { color: var(--color-text-light); font-size: 1.0625rem; }

  .calc-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 3rem; }
  @media (max-width: 768px) { .calc-layout { grid-template-columns: 1fr; } }

  .calc-inputs h2, .calc-result h2 { font-size: 1.25rem; margin-bottom: 1.25rem; }
  .field-group { margin-bottom: 1.25rem; }
  .field-group > label { display: block; font-size: 0.875rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.375rem; }
  .field-group select { width: 100%; padding: 0.625rem 0.875rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: 1rem; background: var(--color-bg); }
  .checkbox-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .check-option { display: flex; align-items: center; gap: 0.5rem; font-size: 0.9375rem; cursor: pointer; }

  .calc-result { background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 1.5rem; }

  .price-box { background: var(--color-primary); color: #fff; border-radius: var(--radius-lg); padding: 1.25rem; margin-bottom: 1.25rem; text-align: center; }
  .price-type { font-size: 0.875rem; opacity: 0.85; margin-bottom: 0.25rem; }
  .price-range { font-size: 2rem; font-weight: 800; }
  .price-unit { font-size: 1rem; font-weight: 400; opacity: 0.8; }
  .price-note { font-size: 0.8125rem; opacity: 0.8; margin-top: 0.25rem; }

  .extras-list { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem; margin-bottom: 1rem; }
  .extras-list h3 { font-size: 0.9375rem; margin-bottom: 0.5rem; }
  .extras-list ul { list-style: none; display: flex; flex-direction: column; gap: 0.375rem; }
  .extras-list li { font-size: 0.875rem; color: var(--color-text-light); }
  .extras-list li::before { content: '• '; color: var(--color-primary); }

  .provider-recs h3 { font-size: 0.9375rem; margin-bottom: 0.75rem; }
  .provider-rec { display: flex; justify-content: space-between; align-items: center; padding: 0.875rem; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); margin-bottom: 0.5rem; gap: 1rem; }
  .provider-rec strong { display: block; font-size: 0.9375rem; }
  .rec-prijs { font-size: 0.875rem; font-weight: 700; color: var(--color-primary); }
  .rec-reden { font-size: 0.8125rem; color: var(--color-text-muted); margin-top: 0.125rem; }
  .btn-sm { padding: 0.375rem 0.875rem; font-size: 0.875rem; white-space: nowrap; }

  .result-cta-block { margin-top: 1rem; }

  .tools-nav { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .tools-nav h2 { margin-bottom: 1rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
  .tool-card { display: flex; flex-direction: column; gap: 0.375rem; padding: 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); text-decoration: none; color: var(--color-text); background: var(--color-bg); transition: all var(--transition-fast); }
  .tool-card:hover { border-color: var(--color-primary); background: var(--color-primary-light); text-decoration: none; }
  .tool-icon { font-size: 1.75rem; }
  .tool-card strong { font-size: 0.9375rem; }
  .tool-card span:last-child { font-size: 0.8125rem; color: var(--color-text-light); }
</style>
