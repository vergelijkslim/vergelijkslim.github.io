---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Hosting Advies Aanvragen"
  description="Ontvang gratis en vrijblijvend advies over de beste webhosting voor jouw situatie."
>
  <main style="padding: 3rem 0;">
    <div class="container" style="max-width: 680px;">
      <h1>Hosting advies aanvragen</h1>
      <p style="color: var(--color-text-light); margin-bottom: 2rem;">Gebruik onze tools om de beste hosting te vinden, of ga direct naar de provider van jouw keuze.</p>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <a href="/tools/vergelijk/" class="btn btn-primary">Hosting vergelijken →</a>
        <a href="/tools/welke-hosting/" class="btn btn-outline">Quiz: welke hosting heb ik nodig?</a>
      </div>
    </div>
  </main>
</BaseLayout>
