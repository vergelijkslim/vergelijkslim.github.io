---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">Vergelijk-uw-<strong>Hosting</strong>.nl</span>
      <p>Onafhankelijk vergelijk- en adviesplatform voor webhosting in Nederland.</p>
    </div>
    <nav class="footer-nav">
      <h4>Tools</h4>
      <ul>
        <li><a href="/tools/vergelijk/">Hosting vergelijken</a></li>
        <li><a href="/tools/welke-hosting/">Welke hosting past bij mij?</a></li>
        <li><a href="/tools/prijscalculator/">Prijscalculator</a></li>
      </ul>
    </nav>
    <nav class="footer-nav">
      <h4>Info</h4>
      <ul>
        <li><a href="/over-ons/">Over ons</a></li>
        <li><a href="/disclaimer/">Disclaimer</a></li>
        <li><a href="/privacy/">Privacy</a></li>
      </ul>
    </nav>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>© {year} Vergelijk-uw-Hosting.nl · <a href="/disclaimer/">Affiliate disclosure</a> · Prijzen zijn indicatief en kunnen afwijken.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--color-bg-alt); border-top: 1px solid var(--color-border); margin-top: 4rem; padding: 3rem 0 0; }
  .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2rem; padding-bottom: 2rem; }
  @media (max-width: 640px) { .footer-inner { grid-template-columns: 1fr; } }
  .footer-brand p { font-size: 0.875rem; color: var(--color-text-light); margin-top: 0.5rem; }
  .footer-logo { font-size: 1rem; font-weight: 400; }
  .footer-logo strong { color: var(--color-primary); font-weight: 700; }
  .footer-nav h4 { font-family: var(--font-sans); font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin-bottom: 0.75rem; }
  .footer-nav ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-nav a { font-size: 0.9375rem; color: var(--color-text-light); }
  .footer-nav a:hover { color: var(--color-primary); }
  .footer-bottom { border-top: 1px solid var(--color-border); padding: 1.25rem 0; }
  .footer-bottom p { font-size: 0.8125rem; color: var(--color-text-muted); }
</style>
