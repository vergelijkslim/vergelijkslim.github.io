---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../lib/affiliate-data';

const structuredData = {
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Vergelijk-uw-Thuisbatterij.nl', url: Astro.site?.href,
  description: 'Onafhankelijke gids voor thuisbatterijen, energieopslag en slim energiebeheer in Nederland', inLanguage: 'nl',
};

const allArticles = (await getCollection('thuisbatterijen'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = allArticles.filter((a) => a.data.featured).slice(0, 3);
const latest = allArticles.slice(0, 6);
const gidsen = allArticles.filter((a) => a.data.type === 'gids');
const vergelijkingen = allArticles.filter((a) => a.data.type === 'vergelijking');

const typeLabels: Record<string, string> = { vergelijking: 'Vergelijking', review: 'Review', gids: 'Gids', regionaal: 'Regionaal' };

const sections = [
  {
    title: 'Gidsen & Advies',
    description: 'Alles over kosten, subsidies en terugverdientijd van thuisbatterijen.',
    href: '/gidsen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    count: gidsen.length,
  },
  {
    title: 'Vergelijkingen',
    description: 'Vergelijk thuisbatterijen op prijs, capaciteit en prestaties.',
    href: '/vergelijkingen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    count: vergelijkingen.length,
  },
  {
    title: 'Offerte aanvragen',
    description: 'Ontvang gratis en vrijblijvend offertes voor een thuisbatterij.',
    href: '/offerte/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    count: 0,
  },
];
---

<BaseLayout
  title="Vergelijk-uw-Thuisbatterij.nl"
  description="Onafhankelijk advies over thuisbatterijen en energieopslag. Vergelijk prijzen, capaciteiten en vind de beste thuisbatterij voor jouw situatie."
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-content">
      <span class="hero-badge">Onafhankelijk & Eerlijk</span>
      <h1>Thuisbatterij vergelijken:<br />vind de beste keuze</h1>
      <p class="hero-sub">
        Vergelijk de populairste thuisbatterijen op prijs, capaciteit en kwaliteit.
        Onafhankelijk advies voor jouw situatie in 2026.
      </p>
      <div class="hero-cta">
        <a href="/artikelen/" class="btn btn-cta">Bekijk alle artikelen</a>
        <a href="/vergelijkingen/" class="btn btn-outline">Vergelijk batterijen</a>
      </div>
    </div>
  </section>

  <section class="trust-bar">
    <div class="container">
      <div class="trust-items">
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>100% onafhankelijk</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v3"/><line x1="12" y1="12" x2="12" y2="16"/></svg>
          <span>Specialist in energieopslag</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Gratis offertes vergelijken</span>
        </div>
      </div>
    </div>
  </section>

  <section class="sections">
    <div class="container">
      <div class="section-header"><h2>Onze onderwerpen</h2><p>Alles over thuisbatterijen, energieopslag en slim energiebeheer.</p></div>
      <div class="section-grid">
        {sections.map((s) => (
          <a href={s.href} class="section-card">
            <div class="section-icon"><Fragment set:html={s.icon} /></div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            {s.count > 0 && <span class="section-meta">{s.count} artikelen &rarr;</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="comparison-table">
    <div class="container">
      <div class="section-header">
        <h2>Populaire thuisbatterijen vergeleken</h2>
        <p>De meest populaire thuisbatterijen in Nederland op een rij.</p>
      </div>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Merk & Model</th>
              <th>Capaciteit</th>
              <th>Prijs (vanaf)</th>
              <th>Prijs/kWh</th>
              <th>Garantie</th>
              <th>Bijzonderheden</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>Sigenergy SigenStor</strong></td><td>5–20 kWh</td><td>€4.500</td><td>~€500/kWh</td><td>10 jaar</td><td>Modulair, incl. omvormer</td></tr>
            <tr><td><strong>Tesla Powerwall 3</strong></td><td>13,5 kWh</td><td>€8.500</td><td>~€630/kWh</td><td>10 jaar</td><td>All-in-one, Tesla-ecosysteem</td></tr>
            <tr><td><strong>BYD HVS</strong></td><td>5,1–12,8 kWh</td><td>€4.200</td><td>~€520/kWh</td><td>10 jaar</td><td>Modulair, breed compatibel</td></tr>
            <tr><td><strong>Huawei LUNA 2000</strong></td><td>5–15 kWh</td><td>€4.800</td><td>~€530/kWh</td><td>10 jaar</td><td>Compact design, goede app</td></tr>
            <tr><td><strong>Growatt APX</strong></td><td>5–12 kWh</td><td>€3.800</td><td>~€480/kWh</td><td>10 jaar</td><td>Scherp geprijsd, modulair</td></tr>
            <tr><td><strong>Zendure SolarFlow</strong></td><td>1,9–7,6 kWh</td><td>€1.200</td><td>~€450/kWh</td><td>10 jaar</td><td>Plug & play, balkoncentrale</td></tr>
          </tbody>
        </table>
      </div>
      <p class="table-note">Prijzen zijn indicatief (april 2026) en exclusief installatiekosten (reken op €1.500–€2.500 extra).</p>
      <div class="table-links">
        <a href="/thuisbatterijen/byd-battery-box-hvs-review/" class="btn btn-primary">BYD HVS Review</a>
        <a href="/thuisbatterijen/huawei-luna-2000-review/" class="btn btn-primary">Huawei LUNA 2000 Review</a>
        <a href="/thuisbatterijen/tesla-powerwall-3-vs-byd-hvs/" class="btn btn-primary">Tesla vs BYD</a>
        <a href="/thuisbatterijen/thuisbatterij-kopen-waar-op-letten/" class="btn btn-primary">Koopgids</a>
      </div>
    </div>
  </section>

  {latest.length > 0 && (
    <section class="latest">
      <div class="container">
        <div class="section-header"><h2>Laatste artikelen</h2><p>Recent gepubliceerd en bijgewerkt.</p></div>
        <div class="latest-grid">
          {latest.map((article) => (
            <a href={`/thuisbatterijen/${article.id}/`} class="latest-card">
              <span class={`badge ${article.data.type === 'gids' ? 'badge-blue' : 'badge-amber'}`}>{typeLabels[article.data.type] || article.data.type}</span>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
            </a>
          ))}
        </div>
        <div class="view-all"><a href="/artikelen/" class="btn btn-primary">Bekijk alle artikelen</a></div>
      </div>
    </section>
  )}

  <section class="faq">
    <div class="container">
      <div class="section-header">
        <h2>Veelgestelde vragen</h2>
        <p>Antwoorden op de meest gestelde vragen over thuisbatterijen.</p>
      </div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Wat kost een thuisbatterij in 2026?</summary>
          <p>Een thuisbatterij kost in 2026 tussen de <strong>€3.500 en €9.000</strong>, afhankelijk van de capaciteit en het merk. Tel daar <strong>€1.500–€2.500</strong> installatiekosten bij op. De gemiddelde investering voor een 10 kWh systeem met installatie ligt rond de <strong>€7.000–€8.500</strong>.</p>
        </details>
        <details class="faq-item">
          <summary>Hoe snel verdien ik een thuisbatterij terug?</summary>
          <p>De terugverdientijd hangt af van je verbruik, het aantal zonnepanelen en je energiecontract. Gemiddeld ligt de terugverdientijd op <strong>7–12 jaar</strong>. Met dynamische tarieven en optimaal gebruik kan dit dalen naar <strong>5–8 jaar</strong>.</p>
        </details>
        <details class="faq-item">
          <summary>Kan ik een thuisbatterij ook zonder zonnepanelen gebruiken?</summary>
          <p>Ja, dat kan. Met een dynamisch energiecontract kun je goedkope stroom opslaan en gebruiken wanneer de prijs hoog is. De terugverdientijd is dan wel langer dan in combinatie met zonnepanelen.</p>
        </details>
        <details class="faq-item">
          <summary>Welke thuisbatterij is het beste voor mij?</summary>
          <p>Dat hangt af van je situatie. Voor de beste prijs-kwaliteitverhouding raden we de <strong>Sigenergy</strong> of <strong>BYD HVS</strong> aan. Voor wie al in het Tesla-ecosysteem zit, is de <strong>Powerwall 3</strong> een logische keuze. Voor kleine installaties is de <strong>Zendure SolarFlow</strong> een betaalbaar instapmodel.</p>
        </details>
        <details class="faq-item">
          <summary>Is een thuisbatterij subsidie mogelijk?</summary>
          <p>In 2026 is er geen landelijke subsidie specifiek voor thuisbatterijen in Nederland. Sommige gemeenten en provincies bieden wel lokale regelingen. Bekijk onze <a href="/thuisbatterijen/thuisbatterij-subsidie-isde/">subsidiegids</a> voor meer informatie.</p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 40%, #2563eb 70%, #3b82f6 100%); color: #fff; padding: 4rem 0 5rem; text-align: center; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(191,219,254,0.15) 0%, transparent 70%); pointer-events: none; }
  .hero-content { position: relative; }
  .hero-badge { display: inline-block; padding: 0.375rem 1rem; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); border-radius: 9999px; font-size: 0.8125rem; font-weight: 500; margin-bottom: 1.5rem; }
  .hero h1 { color: #fff; font-size: 2.5rem; margin-bottom: 1.25rem; letter-spacing: -0.02em; }
  .hero-sub { font-size: 1.125rem; opacity: 0.85; line-height: 1.7; max-width: 560px; margin: 0 auto 2rem; }
  .hero-cta { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .hero-cta .btn { font-size: 1rem; padding: 0.875rem 2rem; }
  .btn-outline { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,0.4); border-radius: var(--radius-lg); }
  .btn-outline:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.7); color: #fff; }
  @media (min-width: 768px) { .hero { padding: 6rem 0 7rem; } .hero h1 { font-size: 3.5rem; } .hero-sub { font-size: 1.25rem; } }

  .trust-bar { background: var(--color-bg); border-bottom: 1px solid var(--color-border); padding: 1.25rem 0; }
  .trust-items { display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap; }
  .trust-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 500; color: var(--color-text-light); }
  .trust-item svg { color: var(--color-primary); flex-shrink: 0; }
  @media (min-width: 768px) { .trust-items { gap: 3rem; } }

  .section-header { text-align: center; margin-bottom: 2.5rem; }
  .section-header p { color: var(--color-text-light); font-size: 1.0625rem; margin-top: 0.5rem; }
  .sections { padding: 4rem 0; }
  .section-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 768px) { .section-grid { grid-template-columns: repeat(3, 1fr); } }
  .section-card { display: block; padding: 2rem; border: 1px solid var(--color-border); border-radius: var(--radius-xl); color: var(--color-text); background: var(--color-bg); transition: all var(--transition-base); }
  .section-card:hover { text-decoration: none; box-shadow: var(--shadow-lg); transform: translateY(-3px); border-color: var(--color-primary-light); }
  .section-icon { display: inline-flex; align-items: center; justify-content: center; width: 56px; height: 56px; border-radius: var(--radius-lg); margin-bottom: 1.25rem; background: var(--color-primary-light); color: var(--color-primary); }
  .section-card h3 { font-family: var(--font-sans); font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem; }
  .section-card p { color: var(--color-text-light); font-size: 0.9375rem; margin-bottom: 1rem; line-height: 1.6; }
  .section-meta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary); }

  .latest { padding: 4rem 0; background: var(--color-bg-alt); }
  .latest-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 640px) { .latest-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .latest-grid { grid-template-columns: repeat(3, 1fr); } }
  .latest-card { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); color: var(--color-text); background: var(--color-bg); transition: all var(--transition-base); }
  .latest-card:hover { text-decoration: none; box-shadow: var(--shadow-sm); border-color: var(--color-primary-light); }
  .latest-card h3 { font-family: var(--font-sans); font-size: 1rem; font-weight: 600; line-height: 1.4; }
  .latest-card p { color: var(--color-text-light); font-size: 0.8125rem; line-height: 1.5; }
  .view-all { text-align: center; margin-top: 2rem; }

  .comparison-table { padding: 4rem 0; }
  .table-wrapper { overflow-x: auto; margin-bottom: 1rem; }
  .table-wrapper table { width: 100%; border-collapse: collapse; font-size: 0.9375rem; }
  .table-wrapper th { background: var(--color-primary); color: #fff; padding: 0.75rem 1rem; text-align: left; font-weight: 600; white-space: nowrap; }
  .table-wrapper td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border); }
  .table-wrapper tr:hover { background: var(--color-bg-alt); }
  .table-note { font-size: 0.8125rem; color: var(--color-text-light); text-align: center; margin-top: 0.5rem; }
  .table-links { display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .table-links .btn { font-size: 0.875rem; padding: 0.625rem 1.25rem; }

  .faq { padding: 4rem 0; background: var(--color-bg-alt); }
  .faq-list { max-width: 720px; margin: 0 auto; }
  .faq-item { border: 1px solid var(--color-border); border-radius: var(--radius-lg); margin-bottom: 0.75rem; background: var(--color-bg); overflow: hidden; }
  .faq-item summary { padding: 1rem 1.25rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; font-size: 0.9375rem; }
  .faq-item summary::after { content: '+'; font-size: 1.25rem; color: var(--color-primary); font-weight: 700; flex-shrink: 0; margin-left: 1rem; }
  .faq-item[open] summary::after { content: '-'; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item p { padding: 0 1.25rem 1rem; color: var(--color-text-light); line-height: 1.7; font-size: 0.9375rem; margin: 0; }
  .faq-item p a { color: var(--color-primary); }
</style>
