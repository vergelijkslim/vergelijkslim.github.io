---
import AffiliateButton from './AffiliateButton.astro';

interface Props {
  title: string;
  description: string;
  linkId: string;
  label?: string;
  variant?: 'blue' | 'amber';
}

const { title, description, linkId, label, variant = 'blue' } = Astro.props;
---

<aside class:list={['inline-cta', `inline-cta-${variant}`]}>
  <div class="inline-cta-content">
    <h4>{title}</h4>
    <p>{description}</p>
  </div>
  <div class="inline-cta-action">
    <AffiliateButton linkId={linkId} label={label} variant="cta" />
  </div>
</aside>

<style>
  .inline-cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    margin: 2rem 0;
  }
  @media (min-width: 640px) {
    .inline-cta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 2rem;
    }
  }
  .inline-cta-blue {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 1px solid #93c5fd;
  }
  .inline-cta-amber {
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border: 1px solid #fde68a;
  }
  .inline-cta-content h4 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .inline-cta-content p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.5;
    margin: 0;
  }
  .inline-cta-action {
    flex-shrink: 0;
  }
</style>
