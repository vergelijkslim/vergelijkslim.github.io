---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import AffiliateButton from '../components/AffiliateButton.astro';
import '../lib/affiliate-data';

const breadcrumbs = [{ name: 'Home', href: '/' }, { name: 'Gratis offerte', href: '/offerte/' }];
const structuredData = {
  '@context': 'https://schema.org', '@type': 'WebPage',
  name: 'Gratis Thuisbatterij Offerte Aanvragen',
  description: 'Ontvang gratis en vrijblijvend offertes voor een thuisbatterij. Vergelijk prijzen van meerdere installateurs.',
};
---

<BaseLayout title="Gratis Thuisbatterij Offerte Aanvragen" description="Ontvang gratis en vrijblijvend offertes voor een thuisbatterij. Vergelijk prijzen van meerdere installateurs en bespaar tot 40%." structuredData={structuredData}>
  <BreadcrumbSchema items={breadcrumbs} />

  <section class="offerte-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><span class="current">Gratis offerte</span></nav>
      <h1>Gratis thuisbatterij offerte aanvragen</h1>
      <p class="hero-sub">Vergelijk offertes van meerdere installateurs en bespaar tot 40% op je thuisbatterij.</p>
    </div>
  </section>

  <section class="offerte-content">
    <div class="container">
      <div class="offerte-grid">
        <div class="offerte-main">
          <div class="step-card">
            <h2>Hoe werkt het?</h2>
            <div class="steps">
              <div class="step">
                <div class="step-number">1</div>
                <div class="step-text">
                  <h3>Vraag offertes aan</h3>
                  <p>Klik op een van de partnerlinks hieronder. Vul je gegevens in en ontvang binnen 48 uur offertes van gecertificeerde installateurs.</p>
                </div>
              </div>
              <div class="step">
                <div class="step-number">2</div>
                <div class="step-text">
                  <h3>Vergelijk en kies</h3>
                  <p>Vergelijk de offertes op prijs, garantie, installatietijd en service. Wij helpen je met onze vergelijkingsgidsen.</p>
                </div>
              </div>
              <div class="step">
                <div class="step-number">3</div>
                <div class="step-text">
                  <h3>Bespaar op je energierekening</h3>
                  <p>Na installatie sla je overtollige zonne-energie op en gebruik je die 's avonds. Bespaar honderden euro's per jaar.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="partners-section">
            <h2>Onze partners</h2>
            <p>Vraag via onderstaande partners gratis en vrijblijvend een offerte aan.</p>
            <div class="partner-cards">
              <div class="partner-card">
                <h3>Thuisbatterij.nl</h3>
                <p>Gespecialiseerd platform voor thuisbatterijen. Vergelijk installateurs bij jou in de buurt.</p>
                <div class="partner-commission">CPA: €50-€150 per lead</div>
                <AffiliateButton linkId="thuisbatterij-offerte" variant="cta" />
              </div>
              <div class="partner-card">
                <h3>SolarClarity</h3>
                <p>Een van de grootste distributeurs van zonne-energie en opslagproducten in de Benelux.</p>
                <div class="partner-commission">CPA: €40-€120 per lead</div>
                <AffiliateButton linkId="solarcity-batterij" variant="cta" />
              </div>
              <div class="partner-card">
                <h3>Coolblue</h3>
                <p>Thuisbatterijen met snelle levering en uitstekende klantenservice.</p>
                <div class="partner-commission">CPS: 4-7% per verkoop</div>
                <AffiliateButton linkId="coolblue-thuisbatterij" variant="primary" />
              </div>
              <div class="partner-card">
                <h3>bol.com</h3>
                <p>Breed assortiment thuisbatterijen en accessoires met klantreviews.</p>
                <div class="partner-commission">CPS: 3-6% per verkoop</div>
                <AffiliateButton linkId="bolcom-thuisbatterij" variant="primary" />
              </div>
            </div>
          </div>
        </div>

        <aside class="offerte-sidebar">
          <div class="sidebar-card">
            <h3>Waarom een thuisbatterij?</h3>
            <ul>
              <li>Sla overtollige zonne-energie op</li>
              <li>Bespaar €300-€800 per jaar</li>
              <li>Minder afhankelijk van het stroomnet</li>
              <li>Stroom bij stroomuitval</li>
              <li>Terugverdientijd: 5-10 jaar</li>
            </ul>
          </div>
          <div class="sidebar-card sidebar-subsidy">
            <h3>Subsidie beschikbaar</h3>
            <p>Via de ISDE-regeling kun je subsidie aanvragen voor een thuisbatterij in combinatie met zonnepanelen.</p>
            <AffiliateButton linkId="subsidie-check" variant="primary" />
          </div>
          <div class="sidebar-card">
            <h3>Vergelijk energieleveranciers</h3>
            <p>Bespaar extra door ook je energieleverancier te vergelijken.</p>
            <AffiliateButton linkId="energieleverancier-vergelijk" variant="primary" />
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .offerte-hero { background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 50%, #2563eb 100%); padding: 3rem 0 3.5rem; color: #fff; }
  .breadcrumb { display: flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; margin-bottom: 1.25rem; }
  .breadcrumb a { color: rgba(255,255,255,0.6); } .breadcrumb a:hover { color: #fff; }
  .breadcrumb .sep { color: rgba(255,255,255,0.4); } .breadcrumb .current { color: rgba(255,255,255,0.8); }
  .offerte-hero h1 { color: #fff; font-size: 2.25rem; margin-bottom: 0.75rem; }
  @media (min-width: 768px) { .offerte-hero { padding: 4rem 0 4.5rem; } .offerte-hero h1 { font-size: 2.75rem; } }
  .hero-sub { color: rgba(255,255,255,0.8); font-size: 1.125rem; max-width: 560px; line-height: 1.7; }

  .offerte-content { padding: 2.5rem 0; }
  .offerte-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .offerte-grid { grid-template-columns: 2fr 1fr; } }

  .step-card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 2rem; margin-bottom: 2rem; }
  .step-card h2 { margin-bottom: 1.5rem; }
  .steps { display: flex; flex-direction: column; gap: 1.5rem; }
  .step { display: flex; gap: 1rem; align-items: flex-start; }
  .step-number { width: 40px; height: 40px; border-radius: 50%; background: var(--color-primary); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.125rem; flex-shrink: 0; }
  .step-text h3 { font-family: var(--font-sans); font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .step-text p { color: var(--color-text-light); font-size: 0.9375rem; line-height: 1.6; }

  .partners-section h2 { margin-bottom: 0.5rem; }
  .partners-section > p { color: var(--color-text-light); margin-bottom: 1.5rem; }
  .partner-cards { display: grid; gap: 1.25rem; }
  @media (min-width: 640px) { .partner-cards { grid-template-columns: repeat(2, 1fr); } }
  .partner-card { border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; background: var(--color-bg); transition: all var(--transition-base); }
  .partner-card:hover { box-shadow: var(--shadow-md); border-color: var(--color-primary-light); }
  .partner-card h3 { font-family: var(--font-sans); font-size: 1.0625rem; font-weight: 600; margin-bottom: 0.5rem; }
  .partner-card p { color: var(--color-text-light); font-size: 0.875rem; line-height: 1.6; margin-bottom: 0.75rem; }
  .partner-commission { font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 1rem; font-style: italic; }

  .sidebar-card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; margin-bottom: 1.25rem; }
  .sidebar-card h3 { font-family: var(--font-sans); font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; }
  .sidebar-card ul { list-style: none; }
  .sidebar-card li { position: relative; padding-left: 1.25rem; margin-bottom: 0.5rem; color: var(--color-text-light); font-size: 0.9375rem; line-height: 1.6; }
  .sidebar-card li::before { content: ''; position: absolute; left: 0; top: 0.5em; width: 6px; height: 6px; border-radius: 50%; background: var(--color-primary); }
  .sidebar-card p { color: var(--color-text-light); font-size: 0.875rem; line-height: 1.6; margin-bottom: 1rem; }
  .sidebar-subsidy { background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border-color: #93c5fd; }
</style>
