---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';
import thuisbatterijen from '../../data/thuisbatterijen.json';

const omvormers = [
  { id: 'sma', label: 'SMA' },
  { id: 'fronius', label: 'Fronius' },
  { id: 'solaredge', label: 'SolarEdge' },
  { id: 'huawei', label: 'Huawei SUN2000' },
  { id: 'growatt', label: 'Growatt' },
  { id: 'kostal', label: 'Kostal' },
  { id: 'abb', label: 'ABB / Fimer' },
  { id: 'tesla', label: 'Tesla' },
  { id: 'anders', label: 'Anders / Onbekend' },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Thuisbatterij configurator – welke batterij past bij jouw installatie?',
  description: 'Vind de juiste thuisbatterij op basis van jouw zonnepanelen en omvormer. Inclusief aanbevolen capaciteit en affiliate links.',
  url: 'https://vergelijk-uw-thuisbatterij.nl/tools/configurator/',
};
---
<BaseLayout
  title="Thuisbatterij Configurator – Welke Batterij Past Bij Jouw Installatie?"
  description="Vul je zonnepanelen en omvormer in en zie direct welke thuisbatterijen compatibel zijn, inclusief aanbevolen capaciteit en prijsvergelijking."
  structuredData={structuredData}
>
  <main class="tool-page">
    <div class="container">
      <div class="tool-header">
        <h1>Batterij configurator</h1>
        <p class="tool-intro">Vul je huidige installatie in en zie welke thuisbatterijen compatibel zijn — gesorteerd op beste match.</p>
      </div>

      <div class="config-layout">
        <!-- Inputs -->
        <div class="config-inputs">
          <h2>Jouw installatie</h2>

          <div class="field-group">
            <label for="aantalPanelen">Aantal zonnepanelen</label>
            <input type="range" id="aantalPanelen" min="4" max="40" value="16" step="1" />
            <output id="panelenOutput">16 panelen</output>
          </div>

          <div class="field-group">
            <label for="panelWp">Vermogen per paneel (Wp)</label>
            <select id="panelWp">
              <option value="300">300 Wp</option>
              <option value="375">375 Wp</option>
              <option value="420" selected>420 Wp</option>
              <option value="480">480 Wp</option>
            </select>
          </div>

          <div class="field-group">
            <label for="omvormer">Huidige omvormer</label>
            <select id="omvormer">
              {omvormers.map(o => <option value={o.id}>{o.label}</option>)}
            </select>
          </div>

          <div class="field-group">
            <label for="jaarVerbruik">Jaarlijks verbruik (kWh)</label>
            <input type="number" id="jaarVerbruik" value="3500" min="1000" max="15000" step="100" />
          </div>

          <div class="install-summary" id="installSummary"></div>
        </div>

        <!-- Resultaten -->
        <div class="config-result">
          <h2>Geschikte batterijen</h2>
          <div id="batterijResults"></div>
        </div>
      </div>

      <!-- Tools nav -->
      <div class="tools-nav">
        <h2>Meer tools</h2>
        <div class="tools-grid">
          <a href="/tools/roi-calculator/" class="tool-card">
            <span class="tool-icon">📈</span>
            <strong>ROI Calculator</strong>
            <span>Bereken de terugverdientijd</span>
          </a>
          <a href="/tools/salderingswijzer/" class="tool-card">
            <span class="tool-icon">📉</span>
            <strong>Salderingswijzer</strong>
            <span>Impact van salderingsafbouw</span>
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script define:vars={{ thuisbatterijen }}>
  function calculate() {
    const panelen = parseInt(document.getElementById('aantalPanelen').value);
    const wp = parseInt(document.getElementById('panelWp').value);
    const omvormer = document.getElementById('omvormer').value;
    const verbruik = parseFloat(document.getElementById('jaarVerbruik').value) || 3500;

    document.getElementById('panelenOutput').textContent = `${panelen} panelen`;

    const totaalWp = panelen * wp;
    const kWp = totaalWp / 1000;
    const productie = Math.round(kWp * 850); // ~850 kWh/kWp in NL
    const overschot = Math.max(0, productie - verbruik);

    // Aanbevolen capaciteit: ~40-60% van dagelijks overschot (mits >0)
    const dagOverschot = overschot / 365;
    const aanbevolenMin = Math.max(5, Math.round(dagOverschot * 0.4 * 10) / 10);
    const aanbevolenMax = Math.max(10, Math.round(dagOverschot * 0.7 * 10) / 10);

    document.getElementById('installSummary').innerHTML = `
      <div class="summary-box">
        <div class="sb-row"><span>Totaal vermogen:</span><span><strong>${kWp.toFixed(1)} kWp</strong></span></div>
        <div class="sb-row"><span>Geschatte productie:</span><span><strong>${productie.toLocaleString('nl-NL')} kWh/jaar</strong></span></div>
        <div class="sb-row"><span>Jaarlijks overschot:</span><span><strong>${overschot.toLocaleString('nl-NL')} kWh/jaar</strong></span></div>
        <div class="sb-row sb-highlight"><span>Aanbevolen capaciteit:</span><span><strong>${aanbevolenMin}–${aanbevolenMax} kWh</strong></span></div>
      </div>
    `;

    // Filter en score batterijen
    const results = thuisbatterijen.map(batterij => {
      // Compatibiliteitscheck
      const omvormerLower = omvormer.toLowerCase();
      const compatibel = batterij.omvormers.some(o =>
        o.toLowerCase() === 'alle' || o.toLowerCase().includes(omvormerLower) || omvormerLower.includes(o.toLowerCase())
      );

      // Score
      let score = batterij.score;
      if (!compatibel) score -= 30;
      if (batterij.capaciteit >= aanbevolenMin && batterij.capaciteit <= aanbevolenMax * 1.5) score += 10;
      const capaciteitMatch = batterij.capaciteit >= aanbevolenMin && batterij.capaciteit <= aanbevolenMax;

      return { ...batterij, compatibel, score, capaciteitMatch };
    }).sort((a, b) => b.score - a.score);

    const container = document.getElementById('batterijResults');
    container.innerHTML = results.map((b, i) => `
      <div class="batterij-card ${!b.compatibel ? 'batterij-card--incompatibel' : ''} ${i === 0 ? 'batterij-card--top' : ''}">
        <div class="bc-header">
          <div>
            ${i === 0 ? '<span class="bc-rank">⭐ Beste match</span>' : i === 1 ? '<span class="bc-rank">🥈 2e keuze</span>' : ''}
            <h3 class="bc-title">${b.merk} ${b.model}</h3>
            ${b.badge ? `<span class="bc-badge">${b.badge}</span>` : ''}
          </div>
          <div class="bc-prijs">€${b.prijs.toLocaleString('nl-NL')}</div>
        </div>
        <div class="bc-specs">
          <div class="bc-spec"><span>Capaciteit</span><strong>${b.capaciteit} kWh ${b.capaciteitMatch ? '✓' : ''}</strong></div>
          <div class="bc-spec"><span>Bruikbaar</span><strong>${b.nuttigeCapaciteit} kWh</strong></div>
          <div class="bc-spec"><span>Vermogen</span><strong>${b.vermogen} kW</strong></div>
          <div class="bc-spec"><span>Garantie</span><strong>${b.garantie} jaar</strong></div>
        </div>
        <div class="bc-compat ${b.compatibel ? 'bc-compat--ok' : 'bc-compat--warn'}">
          ${b.compatibel ? `✓ Compatibel met ${omvormer === 'anders' ? 'de meeste omvormers' : document.getElementById('omvormer').options[document.getElementById('omvormer').selectedIndex].text}` : `⚠️ Mogelijk niet compatibel met jouw omvormer — check bij installateur`}
        </div>
        <div class="bc-actions">
          <a href="${b.affiliateUrl}" target="_blank" rel="nofollow sponsored" class="btn btn-primary btn-sm">${b.affiliateLabel}</a>
        </div>
      </div>
    `).join('');
  }

  ['aantalPanelen', 'panelWp', 'omvormer', 'jaarVerbruik'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', calculate);
    document.getElementById(id)?.addEventListener('change', calculate);
  });

  calculate();
</script>

<style>
  .tool-page { padding: 2rem 0 4rem; }
  .tool-header { margin-bottom: 2rem; }
  .tool-header h1 { margin-bottom: 0.5rem; }
  .tool-intro { color: var(--color-text-light); font-size: 1.0625rem; }

  .config-layout { display: grid; grid-template-columns: 1fr 1.4fr; gap: 2rem; margin-bottom: 3rem; }
  @media (max-width: 900px) { .config-layout { grid-template-columns: 1fr; } }

  .config-inputs h2, .config-result h2 { font-size: 1.25rem; margin-bottom: 1.25rem; }
  .field-group { margin-bottom: 1.25rem; }
  .field-group label { display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 0.375rem; }
  .field-group input[type="range"] { width: 100%; accent-color: var(--color-primary); }
  .field-group input[type="number"], .field-group select { width: 100%; padding: 0.625rem 0.875rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: 1rem; background: var(--color-bg); }
  .field-group output { display: block; text-align: right; font-size: 0.875rem; font-weight: 600; color: var(--color-primary); }

  .summary-box { background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1rem; }
  .sb-row { display: flex; justify-content: space-between; padding: 0.375rem 0; font-size: 0.875rem; border-bottom: 1px solid var(--color-border-light); }
  .sb-row:last-child { border-bottom: none; }
  .sb-highlight { color: var(--color-primary); }

  .batterij-card { border: 2px solid var(--color-border); border-radius: var(--radius-xl); padding: 1.25rem; margin-bottom: 1rem; background: var(--color-bg); }
  .batterij-card--top { border-color: var(--color-primary); background: #eff6ff; }
  .batterij-card--incompatibel { opacity: 0.7; }
  .bc-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; gap: 1rem; }
  .bc-rank { font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); display: block; margin-bottom: 0.25rem; }
  .bc-title { font-size: 1.0625rem; font-weight: 700; font-family: var(--font-sans); margin: 0; }
  .bc-badge { display: inline-block; font-size: 0.6875rem; font-weight: 700; padding: 0.125rem 0.5rem; border-radius: 9999px; background: #dcfce7; color: #166534; margin-top: 0.25rem; }
  .bc-prijs { font-size: 1.25rem; font-weight: 800; color: var(--color-primary); white-space: nowrap; }
  .bc-specs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem; margin-bottom: 0.75rem; }
  @media (max-width: 640px) { .bc-specs { grid-template-columns: repeat(2, 1fr); } }
  .bc-spec { text-align: center; padding: 0.5rem; background: var(--color-bg-alt); border-radius: var(--radius-md); }
  .bc-spec span { display: block; font-size: 0.6875rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 0.125rem; }
  .bc-spec strong { font-size: 0.9375rem; }
  .bc-compat { font-size: 0.875rem; padding: 0.5rem 0.75rem; border-radius: var(--radius-md); margin-bottom: 0.75rem; }
  .bc-compat--ok { background: #dcfce7; color: #166534; }
  .bc-compat--warn { background: #fef3c7; color: #92400e; }
  .bc-actions { display: flex; gap: 0.75rem; }
  .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.75rem 1.5rem; border-radius: var(--radius-md); font-weight: 600; font-size: 0.9375rem; cursor: pointer; transition: all var(--transition-fast); text-decoration: none; border: none; }
  .btn-primary { background: var(--color-primary); color: #fff; }
  .btn-primary:hover { opacity: 0.9; text-decoration: none; color: #fff; }
  .btn-sm { padding: 0.5rem 1.25rem; font-size: 0.875rem; }

  .tools-nav { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .tools-nav h2 { margin-bottom: 1rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
  .tool-card { display: flex; flex-direction: column; gap: 0.375rem; padding: 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); text-decoration: none; color: var(--color-text); background: var(--color-bg); transition: all var(--transition-fast); }
  .tool-card:hover { border-color: var(--color-primary); background: var(--color-primary-light); text-decoration: none; }
  .tool-icon { font-size: 1.75rem; }
  .tool-card strong { font-size: 0.9375rem; }
  .tool-card span:last-child { font-size: 0.8125rem; color: var(--color-text-light); }
</style>
