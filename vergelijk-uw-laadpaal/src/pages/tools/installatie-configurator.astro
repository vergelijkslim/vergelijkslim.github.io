---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Laadpaal installatie configurator – stap-voor-stap kostenraming',
  description: 'Beantwoord 4 vragen over jouw situatie en ontvang een realistische kostenraming voor de installatie van een laadpaal.',
  url: 'https://vergelijk-uw-laadpaal.nl/tools/installatie-configurator/',
};
---
<BaseLayout
  title="Laadpaal Installatie Configurator – Kostenraming in 4 Stappen"
  description="Configureer jouw installatie stap voor stap en ontvang een realistische kostenraming. Inclusief kabellengte, groepsverzwaring en materiaalkosten."
  structuredData={structuredData}
>
  <main class="tool-page">
    <div class="container">
      <div class="tool-header">
        <h1>Installatie configurator</h1>
        <p class="tool-intro">Beantwoord 4 korte vragen en ontvang direct een realistische kostenraming voor jouw specifieke situatie.</p>
      </div>

      <div class="wizard-container">
        <!-- Progress bar -->
        <div class="wizard-progress">
          <div class="progress-steps">
            <div class="progress-step active" data-step="1">
              <div class="step-dot">1</div>
              <div class="step-label">Meterkast</div>
            </div>
            <div class="progress-line"></div>
            <div class="progress-step" data-step="2">
              <div class="step-dot">2</div>
              <div class="step-label">Laadplek</div>
            </div>
            <div class="progress-line"></div>
            <div class="progress-step" data-step="3">
              <div class="step-dot">3</div>
              <div class="step-label">Kabelafstand</div>
            </div>
            <div class="progress-line"></div>
            <div class="progress-step" data-step="4">
              <div class="step-dot">4</div>
              <div class="step-label">Groep</div>
            </div>
          </div>
        </div>

        <!-- Step 1: Meterkast locatie -->
        <div class="wizard-step" id="step1">
          <h2>Waar staat je meterkast?</h2>
          <p class="step-hint">Dit bepaalt hoe gemakkelijk de kabel van meterkast naar laadpaal geleid kan worden.</p>
          <div class="option-grid">
            <button class="option-card" data-step="1" data-value="voorkant" data-label="Voorkant huis">
              <div class="option-icon">🏠</div>
              <div class="option-title">Voorkant huis</div>
              <div class="option-desc">Meterkast bij de voordeur of straatzijde</div>
            </button>
            <button class="option-card" data-step="1" data-value="achterkant" data-label="Achterkant huis">
              <div class="option-icon">🏡</div>
              <div class="option-title">Achterkant huis</div>
              <div class="option-desc">Meterkast bij de achtertuin of achterkant</div>
            </button>
            <button class="option-card" data-step="1" data-value="garage" data-label="In de garage">
              <div class="option-icon">🏗️</div>
              <div class="option-title">In de garage</div>
              <div class="option-desc">Meterkast bevindt zich al in of bij de garage</div>
            </button>
          </div>
        </div>

        <!-- Step 2: Laadpaal locatie -->
        <div class="wizard-step hidden" id="step2">
          <h2>Waar wil je de laadpaal plaatsen?</h2>
          <p class="step-hint">De locatie bepaalt het type montage en eventuele extra materiaalkosten.</p>
          <div class="option-grid">
            <button class="option-card" data-step="2" data-value="oprit" data-label="Oprit">
              <div class="option-icon">🚗</div>
              <div class="option-title">Oprit</div>
              <div class="option-desc">Laadpaal buiten op de oprit of parkeerplaats</div>
            </button>
            <button class="option-card" data-step="2" data-value="garage" data-label="Garage">
              <div class="option-icon">🏠</div>
              <div class="option-title">Garage</div>
              <div class="option-desc">Binnen in de garage aan de muur</div>
            </button>
            <button class="option-card" data-step="2" data-value="carport" data-label="Carport">
              <div class="option-icon">⛺</div>
              <div class="option-title">Carport</div>
              <div class="option-desc">Overdekte parkeerplek buiten</div>
            </button>
          </div>
        </div>

        <!-- Step 3: Kabelafstand -->
        <div class="wizard-step hidden" id="step3">
          <h2>Geschatte kabelafstand</h2>
          <p class="step-hint">De afstand van de meterkast tot de gewenste laadplek (langs de route van de kabel, niet vogelvlucht).</p>
          <div class="slider-section">
            <div class="slider-visual">
              <span class="slider-label-left">1 m</span>
              <input type="range" id="kabelAfstand" min="1" max="30" value="10" step="1" />
              <span class="slider-label-right">30 m</span>
            </div>
            <div class="slider-value-display">
              <span id="kabelAfstandValue">10</span> meter
            </div>
            <div class="slider-tips">
              <div class="slider-tip">
                <strong>1–5 m:</strong> Meterkast direct naast laadplek — minimale kabelkosten
              </div>
              <div class="slider-tip">
                <strong>5–15 m:</strong> Standaard situatie — kabel door muur of langs gevel
              </div>
              <div class="slider-tip">
                <strong>15–30 m:</strong> Langere route — kabelgoot of ondergrondse leiding kan nodig zijn
              </div>
            </div>
          </div>
          <div class="step-nav">
            <button class="btn btn-outline btn-back" data-back="3">← Terug</button>
            <button class="btn btn-primary btn-next" data-next="4">Volgende stap →</button>
          </div>
        </div>

        <!-- Step 4: Groep verzwaren -->
        <div class="wizard-step hidden" id="step4">
          <h2>Moet je groep verzwaard worden?</h2>
          <p class="step-hint">Een laadpaal heeft een aparte groep nodig in de meterkast. Als er geen ruimte meer is, moet de meterkast uitgebreid worden.</p>
          <div class="option-grid">
            <button class="option-card" data-step="4" data-value="nee" data-label="Nee, er is ruimte">
              <div class="option-icon">✅</div>
              <div class="option-title">Nee, er is ruimte</div>
              <div class="option-desc">De meterkast heeft nog een vrije groep beschikbaar</div>
            </button>
            <button class="option-card" data-step="4" data-value="ja" data-label="Ja, nieuwe groep">
              <div class="option-icon">🔌</div>
              <div class="option-title">Ja, nieuwe groep</div>
              <div class="option-desc">Er is nog ruimte in de meterkast, maar een groep moet bijgeplaatst worden</div>
            </button>
            <button class="option-card" data-step="4" data-value="nieuw-bord" data-label="Nieuwe meterkast nodig">
              <div class="option-icon">⚡</div>
              <div class="option-title">Nieuwe meterkast</div>
              <div class="option-desc">De meterkast is vol, een volledig nieuwe meterkast is nodig</div>
            </button>
            <button class="option-card" data-step="4" data-value="onbekend" data-label="Weet ik niet">
              <div class="option-icon">❓</div>
              <div class="option-title">Weet ik niet</div>
              <div class="option-desc">De installateur checkt dit ter plaatse</div>
            </button>
          </div>
        </div>

        <!-- Resultaat -->
        <div class="wizard-step hidden" id="stepResult">
          <h2>Jouw kostenraming</h2>
          <div class="result-summary" id="resultSummary"></div>
          <div class="cost-breakdown-result" id="costBreakdownResult"></div>
          <div class="total-result-box" id="totalResultBox"></div>
          <div class="result-tips" id="resultTips"></div>
          <div class="result-actions">
            <p>Vraag vrijblijvend offertes aan bij gecertificeerde installateurs:</p>
            <AffiliateButton linkId="laadpaal-offerte" label="Ontvang gratis offertes →" variant="cta" />
            <button class="btn btn-outline btn-restart" id="restartBtn">Opnieuw configureren</button>
          </div>
        </div>
      </div>

      <!-- Tools nav -->
      <div class="tools-nav">
        <h2>Meer tools</h2>
        <div class="tools-grid">
          <a href="/tools/vergelijk/" class="tool-card">
            <span class="tool-icon">📊</span>
            <strong>Laadpalen vergelijken</strong>
            <span>Filterable vergelijkingstool</span>
          </a>
          <a href="/tools/totaalkosten/" class="tool-card">
            <span class="tool-icon">💶</span>
            <strong>Totaalkosten calculator</strong>
            <span>Thuis vs publiek vs benzine</span>
          </a>
          <a href="/tools/subsidie/" class="tool-card">
            <span class="tool-icon">💰</span>
            <strong>Subsidie checker</strong>
            <span>Welke subsidies kun jij aanvragen?</span>
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  interface Answers {
    meterkast?: string;
    meterkastLabel?: string;
    laadplek?: string;
    laadplekLabel?: string;
    kabelAfstand?: number;
    groep?: string;
    groepLabel?: string;
  }

  const answers: Answers = {};
  let currentStep = 1;

  function showStep(step: number) {
    document.querySelectorAll('.wizard-step').forEach(el => el.classList.add('hidden'));
    const target = document.getElementById(step === 5 ? 'stepResult' : `step${step}`);
    target?.classList.remove('hidden');
    currentStep = step;

    // Update progress
    document.querySelectorAll('.progress-step').forEach((el) => {
      const s = parseInt((el as HTMLElement).dataset.step || '0');
      el.classList.toggle('active', s === step);
      el.classList.toggle('done', s < step);
    });
  }

  function calculateResult() {
    const afstand = answers.kabelAfstand || 10;
    const groep = answers.groep || 'onbekend';
    const laadplek = answers.laadplek || 'oprit';
    const meterkast = answers.meterkast || 'voorkant';

    // Base costs
    let kabelkosten = Math.round(afstand * 9);
    let arbeidskosten = 220;
    let groepKosten = 0;
    let extraMateriaal = 0;

    // Adjustments
    if (meterkast === 'voorkant' && laadplek === 'garage') kabelkosten += 80; // door huis
    if (laadplek === 'oprit') extraMateriaal += 60; // buitenmontage
    if (laadplek === 'carport') extraMateriaal += 80; // carport montage

    if (groep === 'ja') groepKosten = 85;
    else if (groep === 'nieuw-bord') groepKosten = 450;
    else if (groep === 'onbekend') groepKosten = 0; // shown as unknown

    const laadpaalHardware = 650; // gemiddeld middensegment
    const subtotaalEx = laadpaalHardware + arbeidskosten + kabelkosten + groepKosten + extraMateriaal;
    const btw = Math.round(subtotaalEx * 0.21);
    const totaalIncl = Math.round(subtotaalEx * 1.21);
    const totaalMin = Math.round(totaalIncl * 0.85);
    const totaalMax = Math.round(totaalIncl * 1.20);

    // Summary
    document.getElementById('resultSummary')!.innerHTML = `
      <div class="summary-items">
        <div class="summary-item"><span class="si-label">Meterkast</span><span class="si-value">${answers.meterkastLabel}</span></div>
        <div class="summary-item"><span class="si-label">Laadplek</span><span class="si-value">${answers.laadplekLabel}</span></div>
        <div class="summary-item"><span class="si-label">Kabelafstand</span><span class="si-value">~${afstand} meter</span></div>
        <div class="summary-item"><span class="si-label">Groepsverzwaring</span><span class="si-value">${answers.groepLabel}</span></div>
      </div>
    `;

    const items = [
      { label: 'Laadpaal hardware (richtprijs)', amount: laadpaalHardware, note: 'Middensegment 11 kW smart' },
      { label: 'Arbeidskosten installateur', amount: arbeidskosten, note: '3-fase installatie' },
      { label: 'Kabelwerk', amount: kabelkosten, note: `~${afstand} meter kabel incl. beugels` },
      ...(groepKosten > 0 ? [{ label: 'Groepsverzwaring / meterkast', amount: groepKosten, note: groep === 'nieuw-bord' ? 'Nieuwe meterkast' : 'Extra groep' }] : []),
      ...(extraMateriaal > 0 ? [{ label: 'Extra installatiemateriaal', amount: extraMateriaal, note: 'Montage specifiek voor jouw locatie' }] : []),
      { label: 'BTW (21%)', amount: btw, note: '' },
    ];

    document.getElementById('costBreakdownResult')!.innerHTML = `
      <h3>Kostenoverzicht</h3>
      ${items.map(item => `
        <div class="cost-row">
          <div>
            <span class="cost-label">${item.label}</span>
            ${item.note ? `<small class="cost-note">${item.note}</small>` : ''}
          </div>
          <span class="cost-amount">€${item.amount.toLocaleString('nl-NL')}</span>
        </div>
      `).join('')}
    `;

    document.getElementById('totalResultBox')!.innerHTML = `
      <div class="total-label">Geschatte totaalkosten</div>
      <div class="total-range">€${totaalMin.toLocaleString('nl-NL')} – €${totaalMax.toLocaleString('nl-NL')}</div>
      <div class="total-note">Inclusief BTW. Prijzen zijn richtlijnen — vraag offertes voor exacte kosten.</div>
    `;

    const tips: string[] = [];
    if (groep === 'onbekend') tips.push('💡 De installateur checkt ter plaatse of groepsverzwaring nodig is. Reserveer eventueel €85–€450 extra.');
    if (afstand > 15) tips.push('🔧 Bij lange kabelafstand overweeg een ondergrondse leiding — mooier en beschermd tegen weersomstandigheden.');
    if (groep === 'nieuw-bord') tips.push('⚡ Een nieuwe meterkast combineer je best met andere verbeteringen (extra zekeringen, aardlekschakelaar).');

    document.getElementById('resultTips')!.innerHTML = tips.length > 0 ? `
      <div class="tips-block">
        <h3>Tips voor jouw situatie</h3>
        <ul>${tips.map(t => `<li>${t}</li>`).join('')}</ul>
      </div>
    ` : '';
  }

  // Option card clicks (steps 1, 2, 4)
  document.querySelectorAll('.option-card').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = parseInt((btn as HTMLElement).dataset.step || '0');
      const value = (btn as HTMLElement).dataset.value || '';
      const label = (btn as HTMLElement).dataset.label || '';

      if (step === 1) { answers.meterkast = value; answers.meterkastLabel = label; showStep(2); }
      else if (step === 2) { answers.laadplek = value; answers.laadplekLabel = label; showStep(3); }
      else if (step === 4) {
        answers.groep = value;
        answers.groepLabel = label;
        answers.kabelAfstand = parseInt((document.getElementById('kabelAfstand') as HTMLInputElement).value);
        calculateResult();
        showStep(5);
      }
    });
  });

  // Slider
  const kabelSlider = document.getElementById('kabelAfstand') as HTMLInputElement;
  kabelSlider?.addEventListener('input', () => {
    (document.getElementById('kabelAfstandValue') as HTMLElement).textContent = kabelSlider.value;
  });

  // Next/back buttons for step 3
  document.querySelectorAll('.btn-next').forEach(btn => {
    btn.addEventListener('click', () => {
      const next = parseInt((btn as HTMLElement).dataset.next || '0');
      showStep(next);
    });
  });
  document.querySelectorAll('.btn-back').forEach(btn => {
    btn.addEventListener('click', () => {
      const back = parseInt((btn as HTMLElement).dataset.back || '0');
      showStep(back - 1);
    });
  });

  // Restart
  document.getElementById('restartBtn')?.addEventListener('click', () => {
    Object.keys(answers).forEach(k => delete (answers as any)[k]);
    showStep(1);
  });
</script>

<style>
  .tool-page { padding: 2rem 0 4rem; }
  .tool-header { margin-bottom: 2rem; }
  .tool-header h1 { margin-bottom: 0.5rem; }
  .tool-intro { color: var(--color-text-light); font-size: 1.0625rem; }

  .wizard-container { max-width: 700px; margin: 0 auto 3rem; }

  .wizard-progress { margin-bottom: 2.5rem; }
  .progress-steps { display: flex; align-items: center; gap: 0; }
  .progress-step { display: flex; flex-direction: column; align-items: center; gap: 0.375rem; flex: 1; }
  .progress-line { flex: 1; height: 2px; background: var(--color-border); }
  .step-dot { width: 36px; height: 36px; border-radius: 50%; background: var(--color-border); color: var(--color-text-muted); font-weight: 700; font-size: 0.875rem; display: flex; align-items: center; justify-content: center; transition: all var(--transition-fast); }
  .step-label { font-size: 0.75rem; color: var(--color-text-muted); font-weight: 500; }
  .progress-step.active .step-dot { background: var(--color-primary); color: #fff; }
  .progress-step.active .step-label { color: var(--color-primary); font-weight: 600; }
  .progress-step.done .step-dot { background: var(--color-primary); color: #fff; }
  .progress-step.done .step-dot::after { content: '✓'; }

  .wizard-step h2 { font-size: 1.5rem; margin-bottom: 0.625rem; }
  .step-hint { color: var(--color-text-light); margin-bottom: 1.5rem; font-size: 0.9375rem; }
  .hidden { display: none !important; }

  .option-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
  .option-card { border: 2px solid var(--color-border); border-radius: var(--radius-xl); padding: 1.5rem 1.25rem; text-align: center; background: var(--color-bg); cursor: pointer; transition: all var(--transition-fast); display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .option-card:hover { border-color: var(--color-primary); background: #ecfdf5; transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .option-icon { font-size: 2.25rem; }
  .option-title { font-weight: 700; font-size: 1rem; color: var(--color-text); }
  .option-desc { font-size: 0.8125rem; color: var(--color-text-light); line-height: 1.5; }

  .slider-section { background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 2rem; margin-bottom: 1.5rem; }
  .slider-visual { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
  .slider-label-left, .slider-label-right { font-size: 0.8125rem; color: var(--color-text-muted); font-weight: 600; white-space: nowrap; }
  .slider-visual input[type="range"] { flex: 1; accent-color: var(--color-primary); height: 6px; }
  .slider-value-display { text-align: center; font-size: 2rem; font-weight: 800; color: var(--color-primary); margin-bottom: 1.5rem; }
  .slider-tips { display: flex; flex-direction: column; gap: 0.5rem; }
  .slider-tip { font-size: 0.875rem; color: var(--color-text-light); padding: 0.5rem 0.75rem; background: var(--color-bg); border-radius: var(--radius-md); }

  .step-nav { display: flex; gap: 1rem; justify-content: flex-end; }

  /* Result */
  .summary-items { display: grid; grid-template-columns: 1fr 1fr; gap: 0.625rem; margin-bottom: 1.5rem; }
  .summary-item { background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0.75rem 1rem; }
  .si-label { display: block; font-size: 0.75rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 0.25rem; }
  .si-value { font-weight: 600; font-size: 0.9375rem; color: var(--color-text); }

  .cost-breakdown-result { margin-bottom: 1rem; }
  .cost-breakdown-result h3 { font-size: 1.0625rem; margin-bottom: 0.875rem; }
  .cost-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 0.625rem 0; border-bottom: 1px solid var(--color-border-light); }
  .cost-row:last-child { border-bottom: none; }
  .cost-label { display: block; font-weight: 600; font-size: 0.9375rem; }
  .cost-note { display: block; font-size: 0.8125rem; color: var(--color-text-muted); }
  .cost-amount { font-weight: 700; font-size: 1rem; white-space: nowrap; }

  .total-result-box { background: var(--color-primary); color: #fff; border-radius: var(--radius-lg); padding: 1.25rem; text-align: center; margin-bottom: 1rem; }
  .total-label { font-size: 0.875rem; opacity: 0.85; }
  .total-range { font-size: 1.875rem; font-weight: 800; letter-spacing: -0.02em; }
  .total-note { font-size: 0.8125rem; opacity: 0.8; margin-top: 0.25rem; }

  .tips-block { background: #fefce8; border: 1px solid #fde68a; border-radius: var(--radius-md); padding: 1rem; margin-bottom: 1rem; }
  .tips-block h3 { font-size: 0.9375rem; margin-bottom: 0.5rem; }
  .tips-block ul { list-style: none; display: flex; flex-direction: column; gap: 0.375rem; }
  .tips-block li { font-size: 0.875rem; color: var(--color-text); }

  .result-actions { margin-top: 1.5rem; }
  .result-actions p { font-size: 0.875rem; color: var(--color-text-light); margin-bottom: 0.75rem; }
  .result-actions :global(.btn) { width: 100%; justify-content: center; margin-bottom: 0.75rem; }

  .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.75rem 1.5rem; border-radius: var(--radius-md); font-weight: 600; font-size: 0.9375rem; cursor: pointer; transition: all var(--transition-fast); text-decoration: none; border: none; }
  .btn-primary { background: var(--color-primary); color: #fff; }
  .btn-primary:hover { background: var(--color-primary-dark); text-decoration: none; color: #fff; }
  .btn-outline { background: none; border: 2px solid var(--color-border); color: var(--color-text-light); }
  .btn-outline:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .btn-restart { width: 100%; margin-top: 0.5rem; }
  .btn-back { margin-right: auto; }
  .btn-next { margin-left: auto; }

  .tools-nav { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .tools-nav h2 { margin-bottom: 1rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; }
  .tool-card { display: flex; flex-direction: column; gap: 0.375rem; padding: 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); text-decoration: none; color: var(--color-text); background: var(--color-bg); transition: all var(--transition-fast); }
  .tool-card:hover { border-color: var(--color-primary); background: var(--color-primary-light); text-decoration: none; }
  .tool-icon { font-size: 1.75rem; }
  .tool-card strong { font-size: 0.9375rem; }
  .tool-card span:last-child { font-size: 0.8125rem; color: var(--color-text-light); }
</style>
