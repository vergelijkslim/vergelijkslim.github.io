---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Totaalkosten laadpaal calculator – thuis vs publiek vs benzine',
  description: 'Bereken je maandelijkse laadkosten thuis, vergelijk met publiek laden en benzine. Inclusief terugverdientijd voor je laadpaal.',
  url: 'https://vergelijk-uw-laadpaal.nl/tools/totaalkosten/',
};
---
<BaseLayout
  title="Totaalkosten Laadpaal Calculator – Thuis vs Publiek vs Benzine"
  description="Bereken je maandelijkse laadkosten thuis en vergelijk ze direct met publiek laden en rijden op benzine. Inclusief terugverdientijd laadpaal."
  structuredData={structuredData}
>
  <main class="tool-page">
    <div class="container">
      <div class="tool-header">
        <h1>Totaalkosten laadpaal calculator</h1>
        <p class="tool-intro">Voer je rijgedrag in en zie direct hoeveel je bespaart door thuis te laden ten opzichte van publiek laden of rijden op benzine.</p>
      </div>

      <div class="calc-layout">
        <!-- Inputs -->
        <div class="calc-inputs">
          <h2>Jouw rijprofiel</h2>

          <div class="field-group">
            <label for="evModel">Auto model</label>
            <select id="evModel">
              <option value="custom">Handmatig invoeren</option>
              <option value="14.5">Tesla Model 3 (14.5 kWh/100km)</option>
              <option value="15.5" selected>Tesla Model Y (15.5 kWh/100km)</option>
              <option value="15.5">Volkswagen ID.3 (15.5 kWh/100km)</option>
              <option value="18.5">Volkswagen ID.4 (18.5 kWh/100km)</option>
              <option value="18.0">Hyundai Ioniq 5 (18.0 kWh/100km)</option>
              <option value="16.5">Kia EV6 (16.5 kWh/100km)</option>
              <option value="18.5">BMW iX3 (18.5 kWh/100km)</option>
              <option value="14.5">Peugeot e-208 (14.5 kWh/100km)</option>
              <option value="17.2">Renault Zoe (17.2 kWh/100km)</option>
              <option value="16.2">Nissan Leaf (16.2 kWh/100km)</option>
            </select>
          </div>

          <div class="field-group" id="customKwhGroup" style="display:none">
            <label for="customKwh">Verbruik (kWh per 100 km)</label>
            <input type="number" id="customKwh" value="16" min="10" max="30" step="0.5" />
          </div>

          <div class="field-group">
            <label for="kmPerDag">Kilometers per dag</label>
            <input type="range" id="kmPerDag" min="10" max="200" value="50" step="5" />
            <output id="kmOutput">50 km/dag</output>
          </div>

          <div class="field-group">
            <label for="stroomtarief">Stroomtarief thuis (€ per kWh)</label>
            <input type="number" id="stroomtarief" value="0.32" min="0.10" max="0.60" step="0.01" />
            <small>Gemiddeld NL tarief 2025: ~€0.32/kWh</small>
          </div>

          <div class="field-group">
            <label>Zonnepanelen?</label>
            <div class="toggle-row">
              <label class="toggle-switch">
                <input type="checkbox" id="zonnepanelen" />
                <span class="toggle-track"></span>
              </label>
              <span id="zonLabel">Nee</span>
            </div>
          </div>

          <div class="field-group" id="zonPctGroup" style="display:none">
            <label for="zonPct">Eigen stroom van zonnepanelen (%)</label>
            <input type="range" id="zonPct" min="10" max="80" value="30" step="5" />
            <output id="zonPctOutput">30%</output>
          </div>

          <div class="field-group">
            <label for="laadpaalPrijs">Aanschafprijs laadpaal (€ incl. installatie)</label>
            <input type="number" id="laadpaalPrijs" value="1500" min="500" max="4000" step="100" />
            <small>Gemiddeld €1.200–€2.000 inclusief installatie</small>
          </div>
        </div>

        <!-- Resultaat -->
        <div class="calc-result">
          <h2>Jouw berekening</h2>

          <div class="result-cards" id="resultCards">
            <div class="result-card result-card--home" id="cardThuis">
              <div class="rc-icon">🏠</div>
              <div class="rc-label">Thuis laden</div>
              <div class="rc-amount" id="thuisAmount">–</div>
              <div class="rc-per">per maand</div>
            </div>
            <div class="result-card result-card--public" id="cardPubliek">
              <div class="rc-icon">⚡</div>
              <div class="rc-label">Publiek laden</div>
              <div class="rc-amount" id="publiekAmount">–</div>
              <div class="rc-per">per maand</div>
            </div>
            <div class="result-card result-card--fuel" id="cardBenzine">
              <div class="rc-icon">⛽</div>
              <div class="rc-label">Benzine</div>
              <div class="rc-amount" id="benzineAmount">–</div>
              <div class="rc-per">per maand</div>
            </div>
          </div>

          <div class="chart-container">
            <canvas id="kostenChart"></canvas>
          </div>

          <div class="savings-box" id="savingsBox"></div>

          <div class="roi-box" id="roiBox"></div>

          <div class="result-cta-block">
            <p>Klaar om te starten?</p>
            <AffiliateButton linkId="laadpaal-offerte" label="Ontvang gratis offertes →" variant="cta" />
          </div>
        </div>
      </div>

      <!-- Tools nav -->
      <div class="tools-nav">
        <h2>Meer tools</h2>
        <div class="tools-grid">
          <a href="/tools/vergelijk/" class="tool-card">
            <span class="tool-icon">📊</span>
            <strong>Laadpalen vergelijken</strong>
            <span>Filterable vergelijkingstool</span>
          </a>
          <a href="/tools/installatiekosten/" class="tool-card">
            <span class="tool-icon">🔧</span>
            <strong>Installatiekosten</strong>
            <span>Bereken de totale kosten</span>
          </a>
          <a href="/tools/subsidie/" class="tool-card">
            <span class="tool-icon">💰</span>
            <strong>Subsidie checker</strong>
            <span>Welke subsidies kun jij aanvragen?</span>
          </a>
          <a href="/tools/installatie-configurator/" class="tool-card">
            <span class="tool-icon">🧙</span>
            <strong>Installatie configurator</strong>
            <span>Stap-voor-stap kostenraming</span>
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  // Load Chart.js from CDN
  const chartScript = document.createElement('script');
  chartScript.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
  chartScript.onload = initCalc;
  document.head.appendChild(chartScript);

  let chart: any = null;

  function getKwhPer100(): number {
    const model = (document.getElementById('evModel') as HTMLSelectElement).value;
    if (model === 'custom') {
      return parseFloat((document.getElementById('customKwh') as HTMLInputElement).value) || 16;
    }
    return parseFloat(model) || 15.5;
  }

  function calculate() {
    const kmDag = parseInt((document.getElementById('kmPerDag') as HTMLInputElement).value);
    const tarief = parseFloat((document.getElementById('stroomtarief') as HTMLInputElement).value) || 0.32;
    const heeftZon = (document.getElementById('zonnepanelen') as HTMLInputElement).checked;
    const zonPct = heeftZon ? parseInt((document.getElementById('zonPct') as HTMLInputElement).value) / 100 : 0;
    const laadpaalKosten = parseFloat((document.getElementById('laadpaalPrijs') as HTMLInputElement).value) || 1500;
    const kwhPer100 = getKwhPer100();

    // Update outputs
    (document.getElementById('kmOutput') as HTMLElement).textContent = `${kmDag} km/dag`;
    if (heeftZon) (document.getElementById('zonPctOutput') as HTMLElement).textContent = `${Math.round(zonPct * 100)}%`;

    // kWh per maand
    const kwhPerMaand = kmDag * 30 * (kwhPer100 / 100);

    // Kosten
    const effectiefTarief = tarief * (1 - zonPct);
    const thuisKosten = Math.round(kwhPerMaand * effectiefTarief);
    const publiekKosten = Math.round(kwhPerMaand * 0.47); // gemiddeld NL publiek tarief
    // Benzine equivalent: gemiddeld benzineauto 6.5L/100km, prijs €2.05/L
    const benzineLiterPer100 = 6.5;
    const benzinePrijs = 2.05;
    const benzineKosten = Math.round(kmDag * 30 * (benzineLiterPer100 / 100) * benzinePrijs);

    // Update cards
    (document.getElementById('thuisAmount') as HTMLElement).textContent = `€${thuisKosten.toLocaleString('nl-NL')}`;
    (document.getElementById('publiekAmount') as HTMLElement).textContent = `€${publiekKosten.toLocaleString('nl-NL')}`;
    (document.getElementById('benzineAmount') as HTMLElement).textContent = `€${benzineKosten.toLocaleString('nl-NL')}`;

    // Highlight lowest
    ['cardThuis', 'cardPubliek', 'cardBenzine'].forEach(id => {
      (document.getElementById(id) as HTMLElement).classList.remove('result-card--winner');
    });
    const min = Math.min(thuisKosten, publiekKosten, benzineKosten);
    if (thuisKosten === min) (document.getElementById('cardThuis') as HTMLElement).classList.add('result-card--winner');

    // Savings
    const besparingVsPubliek = publiekKosten - thuisKosten;
    const besparingVsBenzine = benzineKosten - thuisKosten;
    const savingsBox = document.getElementById('savingsBox')!;
    savingsBox.innerHTML = `
      <div class="savings-item">
        <span class="savings-icon">💡</span>
        <div>
          <strong>Je bespaart €${besparingVsPubliek.toLocaleString('nl-NL')} per maand</strong> ten opzichte van publiek laden
        </div>
      </div>
      ${besparingVsBenzine > 0 ? `
      <div class="savings-item">
        <span class="savings-icon">🌱</span>
        <div>
          <strong>Je bespaart €${besparingVsBenzine.toLocaleString('nl-NL')} per maand</strong> ten opzichte van benzine rijden
        </div>
      </div>` : ''}
    `;

    // ROI
    const roiBox = document.getElementById('roiBox')!;
    if (besparingVsPubliek > 0) {
      const maandenRoi = Math.ceil(laadpaalKosten / besparingVsPubliek);
      const jarenRoi = (maandenRoi / 12).toFixed(1);
      roiBox.innerHTML = `
        <div class="roi-label">Terugverdientijd laadpaal</div>
        <div class="roi-value">${maandenRoi <= 60 ? `${jarenRoi} jaar` : `>${Math.floor(60/12)} jaar`}</div>
        <div class="roi-note">Op basis van €${laadpaalKosten.toLocaleString('nl-NL')} aanschaf en €${besparingVsPubliek}/maand besparing vs. publiek laden</div>
      `;
    } else {
      roiBox.innerHTML = '';
    }

    // Update chart
    updateChart(thuisKosten, publiekKosten, benzineKosten);
  }

  function updateChart(thuis: number, publiek: number, benzine: number) {
    if (typeof (window as any).Chart === 'undefined') return;
    const ctx = (document.getElementById('kostenChart') as HTMLCanvasElement).getContext('2d');
    if (!ctx) return;

    if (chart) {
      chart.data.datasets[0].data = [thuis, publiek, benzine];
      chart.update();
      return;
    }

    chart = new (window as any).Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['Thuis laden', 'Publiek laden', 'Benzine'],
        datasets: [{
          label: 'Maandelijkse kosten (€)',
          data: [thuis, publiek, benzine],
          backgroundColor: ['#047857', '#d97706', '#6b7280'],
          borderRadius: 8,
          borderSkipped: false,
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx: any) => ` €${ctx.raw.toLocaleString('nl-NL')} per maand`
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: (val: any) => `€${val}`
            }
          }
        }
      }
    });
  }

  function initCalc() {
    // Event listeners
    const inputs = ['evModel', 'customKwh', 'kmPerDag', 'stroomtarief', 'zonnepanelen', 'zonPct', 'laadpaalPrijs'];
    inputs.forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('input', onInput);
        el.addEventListener('change', onInput);
      }
    });
    calculate();
  }

  function onInput(e: Event) {
    const target = e.target as HTMLInputElement;

    // Toggle custom kWh field
    if (target.id === 'evModel') {
      const customGroup = document.getElementById('customKwhGroup')!;
      customGroup.style.display = target.value === 'custom' ? 'block' : 'none';
    }

    // Toggle solar percentage field
    if (target.id === 'zonnepanelen') {
      const zonGroup = document.getElementById('zonPctGroup')!;
      zonGroup.style.display = target.checked ? 'block' : 'none';
      (document.getElementById('zonLabel') as HTMLElement).textContent = target.checked ? 'Ja' : 'Nee';
    }

    calculate();
  }

  // Init without chart if script hasn't loaded yet (fallback)
  if (typeof (window as any).Chart !== 'undefined') {
    initCalc();
  }
</script>

<style>
  .tool-page { padding: 2rem 0 4rem; }
  .tool-header { margin-bottom: 2rem; }
  .tool-header h1 { margin-bottom: 0.5rem; }
  .tool-intro { color: var(--color-text-light); font-size: 1.0625rem; }

  .calc-layout { display: grid; grid-template-columns: 1fr 1.2fr; gap: 2rem; margin-bottom: 3rem; }
  @media (max-width: 900px) { .calc-layout { grid-template-columns: 1fr; } }

  .calc-inputs h2, .calc-result h2 { font-size: 1.25rem; margin-bottom: 1.25rem; }
  .field-group { margin-bottom: 1.25rem; }
  .field-group label { display: block; font-size: 0.875rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.375rem; }
  .field-group input[type="number"], .field-group select {
    width: 100%; padding: 0.625rem 0.875rem; border: 1px solid var(--color-border);
    border-radius: var(--radius-md); font-size: 1rem; background: var(--color-bg);
  }
  .field-group input[type="range"] { width: 100%; accent-color: var(--color-primary); }
  .field-group output { display: block; text-align: right; font-size: 0.875rem; font-weight: 600; color: var(--color-primary); }
  .field-group small { display: block; font-size: 0.8125rem; color: var(--color-text-muted); margin-top: 0.25rem; }

  .toggle-row { display: flex; align-items: center; gap: 0.75rem; }
  .toggle-switch { position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; }
  .toggle-switch input { opacity: 0; width: 0; height: 0; }
  .toggle-track { position: absolute; inset: 0; background: var(--color-border); border-radius: 9999px; transition: background var(--transition-fast); cursor: pointer; }
  .toggle-track::before { content: ''; position: absolute; width: 18px; height: 18px; left: 3px; top: 3px; background: #fff; border-radius: 50%; transition: transform var(--transition-fast); }
  .toggle-switch input:checked + .toggle-track { background: var(--color-primary); }
  .toggle-switch input:checked + .toggle-track::before { transform: translateX(20px); }

  .result-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
  .result-card { border: 2px solid var(--color-border); border-radius: var(--radius-lg); padding: 1rem 0.75rem; text-align: center; background: var(--color-bg); transition: all var(--transition-fast); }
  .result-card--winner { border-color: var(--color-primary); background: #ecfdf5; }
  .rc-icon { font-size: 1.5rem; margin-bottom: 0.25rem; }
  .rc-label { font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 0.375rem; }
  .rc-amount { font-size: 1.375rem; font-weight: 800; color: var(--color-text); }
  .result-card--winner .rc-amount { color: var(--color-primary); }
  .rc-per { font-size: 0.6875rem; color: var(--color-text-muted); }

  .chart-container { margin-bottom: 1.5rem; background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1rem; }

  .savings-box { display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 1rem; }
  .savings-item { display: flex; gap: 0.625rem; align-items: flex-start; padding: 0.75rem; background: #ecfdf5; border: 1px solid #6ee7b7; border-radius: var(--radius-md); font-size: 0.9375rem; line-height: 1.5; }
  .savings-icon { font-size: 1.25rem; flex-shrink: 0; }

  .roi-box { background: var(--color-primary); color: #fff; border-radius: var(--radius-lg); padding: 1.25rem; margin-bottom: 1rem; text-align: center; }
  .roi-label { font-size: 0.875rem; opacity: 0.85; }
  .roi-value { font-size: 2rem; font-weight: 800; letter-spacing: -0.03em; }
  .roi-note { font-size: 0.8125rem; opacity: 0.8; margin-top: 0.25rem; }

  .result-cta-block { margin-top: 1rem; }
  .result-cta-block p { font-size: 0.875rem; color: var(--color-text-light); margin-bottom: 0.5rem; }
  .result-cta-block :global(.btn) { width: 100%; justify-content: center; }

  .tools-nav { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .tools-nav h2 { margin-bottom: 1rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; }
  .tool-card { display: flex; flex-direction: column; gap: 0.375rem; padding: 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); text-decoration: none; color: var(--color-text); background: var(--color-bg); transition: all var(--transition-fast); }
  .tool-card:hover { border-color: var(--color-primary); background: var(--color-primary-light); text-decoration: none; }
  .tool-icon { font-size: 1.75rem; }
  .tool-card strong { font-size: 0.9375rem; }
  .tool-card span:last-child { font-size: 0.8125rem; color: var(--color-text-light); }
</style>
